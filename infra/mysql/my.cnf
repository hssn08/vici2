# =============================================================================
# vici2 MySQL 8.0.40 baseline — Phase 1 (24 GB RAM dev/MVP box).
# Per F02 PLAN §2.1.
#
# Mounted into the mysql:8.0.40 container at
#   /etc/mysql/conf.d/vici2.cnf
# (see docker-compose.dev.yml).
#
# Production preset for the 64 GB box lives at
#   infra/mysql/my.prod.cnf.example  (operator copies + tunes)
# =============================================================================

[mysqld]
# --- Engine + identity ---
default_storage_engine            = InnoDB
default_authentication_plugin     = caching_sha2_password
character_set_server              = utf8mb4
collation_server                  = utf8mb4_0900_ai_ci
default_time_zone                 = '+00:00'
sql_mode = 'STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,NO_ZERO_DATE,NO_ZERO_IN_DATE,ERROR_FOR_DIVISION_BY_ZERO'

# --- Memory (Phase 1 24GB box; F02 PLAN §2.1) ---
innodb_buffer_pool_size           = 16G
innodb_buffer_pool_instances      = 8
innodb_buffer_pool_chunk_size     = 128M
innodb_dedicated_server           = OFF

# --- Redo log (8.0.30+ replaces innodb_log_file_size) ---
innodb_redo_log_capacity          = 4G

# --- Durability (NOT NEGOTIABLE — telephony writes are TCPA evidence) ---
innodb_flush_log_at_trx_commit    = 1
sync_binlog                       = 1
innodb_flush_method               = O_DIRECT
innodb_doublewrite                = ON

# --- I/O (cloud NVMe baseline) ---
innodb_io_capacity                = 8000
innodb_io_capacity_max            = 16000
innodb_read_io_threads            = 8
innodb_write_io_threads           = 8

# --- Concurrency ---
innodb_thread_concurrency         = 0
innodb_purge_threads              = 4
innodb_adaptive_hash_index        = ON
innodb_adaptive_hash_index_parts  = 8

# --- Replication / binlog ---
log_bin                           = mysql-bin
binlog_format                     = ROW
binlog_row_image                  = MINIMAL
binlog_expire_logs_seconds        = 604800
gtid_mode                         = ON
enforce_gtid_consistency          = ON

# --- Connections ---
max_connections                   = 500
thread_cache_size                 = 100
table_open_cache                  = 4000

# --- Slow query log ---
slow_query_log                    = ON
long_query_time                   = 0.5
log_queries_not_using_indexes     = ON

# --- Misc safety ---
local_infile                      = OFF
