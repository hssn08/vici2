{
  "annotations": {"list": []},
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "MySQL Up",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "targets": [{"expr": "mysql_up", "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}]}},
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "stat",
      "title": "Connections in Use",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "targets": [{"expr": "mysql_global_status_threads_connected", "refId": "A"}],
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "stat",
      "title": "QPS",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "targets": [{"expr": "rate(mysql_global_status_queries[5m])", "refId": "A"}],
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "stat",
      "title": "Slow Queries (/s)",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "targets": [{"expr": "rate(mysql_global_status_slow_queries[5m])", "refId": "A"}],
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "timeseries",
      "title": "InnoDB Buffer Pool Hit Ratio",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 5,
      "targets": [{"expr": "1 - (rate(mysql_global_status_innodb_buffer_pool_reads[5m]) / rate(mysql_global_status_innodb_buffer_pool_read_requests[5m]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}},
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "timeseries",
      "title": "Replication Lag",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 6,
      "targets": [{"expr": "mysql_slave_lag_seconds", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s"}},
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "timeseries",
      "title": "Connection Saturation",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "id": 7,
      "targets": [{"expr": "mysql_global_status_threads_connected / mysql_global_variables_max_connections", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit"}},
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "timeseries",
      "title": "Transactions / sec",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "id": 8,
      "targets": [
        {"expr": "rate(mysql_global_status_commands_total{command=\"commit\"}[5m])", "refId": "A", "legendFormat": "commit"},
        {"expr": "rate(mysql_global_status_commands_total{command=\"rollback\"}[5m])", "refId": "B", "legendFormat": "rollback"}
      ],
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["vici2", "mysql"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "utc",
  "title": "vici2 / MySQL",
  "uid": "mysql",
  "version": 1
}
