      "type": "timeseries",
      "title": "Agent State Breakdown",
      "gridPos": {"h": 10, "w": 16, "x": 0, "y": 0},
      "id": 1,
      "targets": [{"expr": "vici2:agent_state_count:by_state", "refId": "A", "legendFormat": "{{state}}"}],
      "fieldConfig": {"defaults": {"custom": {"stacking": {"mode": "normal"}, "fillOpacity": 60}}},
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "piechart",
      "title": "Pause Codes",
      "gridPos": {"h": 10, "w": 8, "x": 16, "y": 0},
      "id": 2,
      "targets": [{"expr": "vici2_agent_pause_code_count", "refId": "A", "legendFormat": "{{pause_code}}", "instant": true}],
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "timeseries",
      "title": "Calls Handled by Disposition (/s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 3,
      "targets": [{"expr": "vici2:agent_calls_handled_rate:5m", "refId": "A", "legendFormat": "{{disposition}}"}],
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "timeseries",
      "title": "AHT p95 (in-call duration)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "id": 4,
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(vici2_agent_state_duration_seconds_bucket{state=\"incall\"}[15m])))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s"}},
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "timeseries",
      "title": "State Transitions (/s)",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 18},
      "id": 5,
      "targets": [{"expr": "sum by (from, to) (rate(vici2_agent_state_transitions_total[5m]))", "refId": "A", "legendFormat": "{{from}} -> {{to}}"}],
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    }
