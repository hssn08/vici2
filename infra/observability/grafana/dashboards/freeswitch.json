      "fieldConfig": {"defaults": {"unit": "s"}},
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "timeseries",
      "title": "ESL Reconnects (/s)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "id": 8,
      "targets": [{"expr": "rate(vici2_esl_reconnects_total[5m])", "refId": "A", "legendFormat": "{{fs_host}}"}],
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
