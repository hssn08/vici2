  "panels": [
    {
      "type": "stat",
      "title": "Calls Active",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "targets": [{"expr": "vici2:freeswitch_calls_active:sum", "refId": "A"}],
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "stat",
      "title": "Conferences Active",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "targets": [{"expr": "sum(vici2_freeswitch_conferences_active)", "refId": "A"}],
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "stat",
      "title": "ESL Connection State",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "targets": [{"expr": "vici2_esl_connection_status", "refId": "A", "legendFormat": "{{fs_host}}"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}]}},
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "stat",
      "title": "FS Uptime",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "targets": [{"expr": "vici2_freeswitch_uptime_seconds", "refId": "A", "legendFormat": "{{fs_host}}"}],
      "fieldConfig": {"defaults": {"unit": "s"}},
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "timeseries",
      "title": "Channels Active",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 5,
      "targets": [{"expr": "vici2_freeswitch_channels_active", "refId": "A", "legendFormat": "{{fs_host}}"}],
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "timeseries",
      "title": "Conference Participants by Kind",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 6,
      "targets": [{"expr": "sum by (kind) (vici2_freeswitch_conference_participants)", "refId": "A", "legendFormat": "{{kind}}"}],
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "timeseries",
      "title": "ESL Event Latency p99",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
