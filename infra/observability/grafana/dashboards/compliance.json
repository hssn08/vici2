{
  "annotations": {"list": []},
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "timeseries",
      "title": "Drop Rate per Campaign (with FCC 3% ceiling)",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "targets": [{"expr": "vici2_dialer_drop_ratio", "refId": "A", "legendFormat": "campaign={{campaign_id}}"}],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.025}, {"color": "red", "value": 0.03}]},
          "custom": {"thresholdsStyle": {"mode": "line"}}
        }
      },
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "stat",
      "title": "DNC Scrub Pass Rate (5m)",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 10},
      "id": 2,
      "targets": [{"expr": "sum(rate(vici2_compliance_dnc_scrub_total{result=\"pass\"}[5m])) / sum(rate(vici2_compliance_dnc_scrub_total[5m]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.99}, {"color": "green", "value": 0.999}]}}},
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "stat",
      "title": "DNC Bypass Events (24h)",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 10},
      "id": 3,
      "targets": [{"expr": "increase(vici2_compliance_dnc_bypass_total[24h])", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "red", "value": 1}]}}},
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "stat",
      "title": "TCPA Window Violations (24h)",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 10},
      "id": 4,
      "targets": [{"expr": "increase(vici2_compliance_tcpa_outside_window_total[24h])", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "red", "value": 1}]}}},
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "stat",
      "title": "Missing Recording Consent (24h)",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 10},
      "id": 5,
      "targets": [{"expr": "increase(vici2_compliance_recording_consent_missing_total[24h])", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "red", "value": 1}]}}},
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "timeseries",
      "title": "Timezone-Gate Blocks (/s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "id": 6,
      "targets": [{"expr": "sum by (reason) (rate(vici2_compliance_timezone_gate_blocked_total[5m]))", "refId": "A", "legendFormat": "{{reason}}"}],
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "timeseries",
      "title": "Audit Log Write Rate",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "id": 7,
      "targets": [{"expr": "sum by (outcome) (rate(vici2_compliance_audit_log_writes_total[5m]))", "refId": "A", "legendFormat": "{{outcome}}"}],
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "table",
      "title": "Compliance Alerts Firing",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 22},
      "id": 8,
      "targets": [{"expr": "ALERTS{alertstate=\"firing\", compliance=\"true\"}", "refId": "A", "instant": true, "format": "table"}],
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    }
  ],
