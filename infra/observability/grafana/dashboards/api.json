      "id": 2,
      "targets": [{"expr": "vici2:api_error_rate_5xx:5m", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit"}},
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "type": "timeseries",
      "title": "Request Duration p50 / p95 / p99",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
