// vici2 — F02 MySQL 8 schema (Prisma source of truth)
//
// Conventions (FROZEN per F02 PLAN §3):
//  - PK: BigInt auto-increment, except phone_codes / phone_codes_overrides /
//    zip_codes (NANP reference) and join tables with composite PKs.
//  - tenant_id: BigInt @default(1) on every table except the four global
//    reference tables noted above.
//  - Timestamps: DateTime(6) created_at / updated_at on every table.
//  - VARBINARY(512) ciphertext columns + kek_version SMALLINT for envelope
//    encryption (F05 owns the cipher).
//  - JSON columns are MySQL native JSON; Zod-validated in app code.
//  - Enums for fixed business vocabularies; lookup tables for vocabularies
//    that grow (statuses, pause_codes, audit_log.action / entity_type).
//  - Composite indexes lead with tenant_id (CI script enforces).
//
// Migrations FROZEN sequence (Prisma autogenerates timestamps; logical order):
//   0_init                 → all non-partitioned tables + audit_log model
//   1_partition_log_tables → drops Prisma-emitted CREATE TABLE for the 5
//                            log tables and re-creates with PARTITION BY
//                            RANGE COLUMNS (+3 months pre-creation)
//   2_drop_partition_fks   → drops any FK Prisma emitted for those tables
//   3_audit_grants         → creates vici2_app/backup/root + REVOKEs
//                            UPDATE/DELETE on audit_log from vici2_app
//
// Amendments applied (per orchestrator brief):
//   A1: phone_codes PK extended to (area_code, exchange_code) — NXX granular
//   A2: users.totp_required BOOLEAN DEFAULT false (F05 hook)
//   A3: auth_config single-row table (F05 hook)
//   A4: zip_codes table (D03 ZIP cascade)
//   A5: phone_codes_overrides (D03 manual override resolver)
//   A6: bootstrap super_admin shape (no row seeded — F05 owns)
//
// C03 — audit immutability chain columns + audit_attestation table:
//   C03.1  audit_log.prev_hash / row_hash / hash_at (BEFORE INSERT trigger computes)
//   C03.2  call_window_audit chain columns
//   C03.3  originate_audit chain columns
//   C03.4  consent_log table (C02-owned schema; C03 adds chain + immutability)
//   C03.5  dnc_sync_log chain columns
//   C03.6  audit_attestation table (signed daily Merkle attestation records)
//
// Wave-5 amendments (feat/F02-amendments — additive only, no DROP):
//   C01.1  call_window_audit table (partitioned, INSERT-only) — TCPA decisions log
//   C01.2  state_holidays table (admin-display lookup; non-partitioned)
//   C01.3  campaigns.unknown_tz_policy ENUM('deny','warn_pass') DEFAULT 'deny'
//   C01.4  leads.tz_blocked TINYINT(1) DEFAULT 0  (M03 admin-review flag)
//   T02.1  carriers.kind ENUM widened from 5 → 8 values (telnyx-creds/-ip,
//          bandwidth, flowroute added; legacy 'telnyx' kept for back-compat)
//   T02.2  carriers.send_pai BOOLEAN DEFAULT false  (per-call PAI default)
//   T02.3  carriers.is_emergency BOOLEAN DEFAULT false  (E911 tag)
//   T02.4  carriers.max_concurrent INT NULL  (carrier-wide concurrency cap)
//   T02.5  carriers.notes JSON NOT NULL DEFAULT (JSON_OBJECT())  (operator memos)
//   T02.6  carriers.version INT NOT NULL DEFAULT 1  (optimistic concurrency)
//   T02.7  gateways.weight SMALLINT NOT NULL DEFAULT 100  (Phase-2 distributor)
//   T02.8  gateways.max_concurrent INT NULL
//   T02.9  gateways.version INT NOT NULL DEFAULT 1
//   T02.10 gateways.cost_per_min_cents INT NULL  (Phase-2 forward-compat)
//   D01.1  leads.version SMALLINT NOT NULL DEFAULT 1  (optimistic-lock token)
//   D05.1  tenant_id=0 sentinel row supported by FK (seed insert id=0)
//   D05.2  dnc_sync_config table (per-source cadence + last/next_run_at)
//   D05.3  dnc_sync_log table (partitioned, INSERT-only) — sync run summaries
//   D05.4  tenants.internal_dnc_retention_years SMALLINT DEFAULT 5  (max 99)
//   E01.1  campaigns.dial_level DECIMAL(4,2) DEFAULT 1.50
//   E01.2  campaigns.dial_timeout_sec already exists; re-named not needed
//   E01.3  campaigns.lock_ttl_sec SMALLINT DEFAULT 30
//   E01.4  campaigns.min_hopper_level INT DEFAULT 50
//   E01.5  campaigns.max_hopper_level INT DEFAULT 5000
//   E01.6  campaigns.hopper_buffer_multiplier DECIMAL(3,1) DEFAULT 1.5
//   E01.7  campaigns.recycle_delay_seconds INT DEFAULT 600
//   E01.8  campaigns.max_calls_per_lead TINYINT DEFAULT 5
//   E01.9  campaigns.dial_statuses JSON DEFAULT (JSON_ARRAY('NEW','NA','B','CALLBK'))
//   E01.10 campaigns.low_water_pct TINYINT DEFAULT 25
//   E01.11 campaigns.high_water_pct TINYINT DEFAULT 90
//   E01.12 campaigns.over_fetch_ratio DECIMAL(3,1) DEFAULT 1.5
//   E01.13 campaigns.machine_terminal BOOL DEFAULT true
//   E01.14 campaigns.lead_filter_sql TEXT NULL
//   E01.15 campaigns.multi_list_mix ENUM('EVEN','MULTI','NONE') DEFAULT 'EVEN'
//   E01.16 campaign_status_overrides table (per-campaign status recycle override)
//   T04.1  originate_audit table (partitioned by originated_at; INSERT+UPDATE-once)
//   T04.2  4 new D04 statuses seeded: TCPA, CONSENT_NOT_OBTAINED,
//          CARRIER_FAIL, GATEWAY_LIMIT_TRY_LATER (under campaign_id='__SYS__')
//   T04.3  lists.caller_id_override VARCHAR(16) NULL
//   T04.4  lists.caller_id_name VARCHAR(32) NULL
//
// C02 amendments (feat/C02-implement — additive only, no DROP):
//   C02.1  tenants.consent_minimum_mode ENUM ConsentMode DEFAULT 'PROMPT_MESSAGE'
//   C02.2  tenants.default_caller_state CHAR(2) NULL
//   C02.3  campaigns.consent_policy_override ENUM ConsentMode NULL
//   C02.4  campaigns.recording_purpose ENUM RecordingPurpose DEFAULT 'general'
//   C02.5  campaigns.opt_out_action ENUM OptOutAction DEFAULT 'continue_no_record'
//   C02.6  campaigns.consent_msg_audio VARCHAR(255) NULL
//   C02.7  leads.is_business TINYINT(1) DEFAULT 0
//   C02.8  consent_log table (partitioned, INSERT-only) — per-call consent audit
//
// E04 amendments (feat/F02-amendments — additive only, no DROP):
//   E04.1  campaigns.lead_lock_ttl_seconds INT NOT NULL DEFAULT 30
//          (distinct from E01.3 lock_ttl_sec: lock_ttl_sec is the hopper-lock TTL;
//           lead_lock_ttl_seconds is the SET NX EX fence that prevents double-dial)
//   E04.2  campaigns.call_strategy ENUM('longest_wait','random','fewest_calls','rank')
//          NOT NULL DEFAULT 'longest_wait'
//          (additive alongside E01's next_agent_call; E04 picker reads call_strategy;
//           Phase 3 will unify; today only longest_wait is implemented)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// 4.1  tenants
// =============================================================================

model Tenant {
  id                        BigInt   @id @default(autoincrement())
  name                      String   @db.VarChar(128)
  slug                      String   @unique @db.VarChar(64)
  active                    Boolean  @default(true)
  settings                  Json
  // D05 amendment — per-tenant FCC 64.1200(d) internal-DNC retention,
  // default 5 years (FCC floor); operator may extend up to 99.
  internalDncRetentionYears Int                  @default(5) @map("internal_dnc_retention_years") @db.SmallInt
  // C02 amendment §9.2 — recording-consent minimum mode (default PROMPT_MESSAGE = safe floor).
  // M05 surfaces this in the tenant editor. ModeSkip = no recording ever.
  consentMinimumMode        ConsentMode          @default(PROMPT_MESSAGE) @map("consent_minimum_mode")
  // C02 amendment §9.2 — dialer's outbound caller state (Phase 1: per-tenant;
  // Phase 4: per-user via users.state). Used by CheckConsent's stricter-state-wins.
  defaultCallerState        String?              @map("default_caller_state") @db.Char(2)
  createdAt                 DateTime             @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt                 DateTime             @updatedAt @map("updated_at") @db.DateTime(6)

  users          User[]
  userGroups     UserGroup[]
  sipCredentials SipCredential[]
  campaigns      Campaign[]
  lists          List[]
  leads          Lead[]
  statuses       Status[]
  pauseCodes     PauseCode[]
  scripts        Script[]
  callTimes      CallTime[]
  dnc            Dnc[]
  callbacks      Callback[]
  hopperMirror   HopperMirror[]
  recordings     Recording[]
  dispositions   Disposition[]
  carriers       Carrier[]
  gateways       Gateway[]
  didNumbers     DidNumber[]
  ingroups       Ingroup[]
  ingroupAgents  IngroupAgent[]
  ivrTrees       IvrTree[]
  settingsRows   Setting[]
  imports        Import[]

  @@map("tenants")
}

// =============================================================================
// 4.2  users   (A2 amendment: totp_required)
// =============================================================================

enum UserRole {
  agent
  supervisor
  admin
  superadmin
  integrator
}

model User {
  id            BigInt    @id @default(autoincrement())
  tenantId      BigInt    @default(1) @map("tenant_id")
  username      String    @db.VarChar(64)
  email         String?   @db.VarChar(128)
  // F02 ships VARCHAR(255) per amendment A6 — Argon2id encoded length;
  // F05 owns hashing and may persist its own width when it lands.
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  fullName      String?   @map("full_name") @db.VarChar(128)
  role          UserRole
  userGroupId   BigInt?   @map("user_group_id")
  active        Boolean   @default(true)
  hotkeysActive Boolean   @default(true) @map("hotkeys_active")
  totpRequired  Boolean   @default(false) @map("totp_required")
  lastLoginAt   DateTime? @map("last_login_at") @db.DateTime(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.DateTime(6)

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_users_tenant")
  userGroup      UserGroup?      @relation(fields: [userGroupId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_users_user_group")
  sipCredentials SipCredential[]
  callbacks      Callback[]      @relation("CallbacksOwner")
  callbacksMade  Callback[]      @relation("CallbacksCreatedBy")
  ingroupAgents  IngroupAgent[]
  ownedLeads     Lead[]
  dispositions   Disposition[]
  imports        Import[]

  @@unique([tenantId, username], map: "uk_users_tenant_username")
  @@unique([tenantId, email], map: "uk_users_tenant_email")
  @@index([tenantId, userGroupId], map: "idx_users_t_group")
  @@index([tenantId, role, active], map: "idx_users_t_role_active")
  @@map("users")
}

// =============================================================================
// 4.3  user_groups
// =============================================================================

model UserGroup {
  id               BigInt   @id @default(autoincrement())
  tenantId         BigInt   @default(1) @map("tenant_id")
  name             String   @db.VarChar(64)
  allowedCampaigns Json     @map("allowed_campaigns")
  allowedIngroups  Json     @map("allowed_ingroups")
  createdAt        DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.DateTime(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_user_groups_tenant")
  users  User[]

  @@unique([tenantId, name], map: "uk_user_groups_tenant_name")
  @@map("user_groups")
}

// =============================================================================
// 4.4  sip_credentials  (envelope-encrypted)
// =============================================================================

model SipCredential {
  id            BigInt    @id @default(autoincrement())
  tenantId      BigInt    @default(1) @map("tenant_id")
  userId        BigInt    @map("user_id")
  sipUsername   String    @map("sip_username") @db.VarChar(64)
  sipPasswordCt Bytes     @map("sip_password_ct") @db.VarBinary(512)
  kekVersion    Int       @default(1) @map("kek_version") @db.SmallInt
  lastRotatedAt DateTime? @map("last_rotated_at") @db.DateTime(6)
  revokedAt     DateTime? @map("revoked_at") @db.DateTime(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.DateTime(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_sip_creds_tenant")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_sip_creds_user")

  @@unique([tenantId, sipUsername], map: "uk_sip_creds_tenant_user")
  @@index([tenantId, userId, kekVersion], map: "idx_sip_creds_t_user_kek")
  @@map("sip_credentials")
}

// =============================================================================
// 4.5  audit_log  (partitioned in 1_partition_log_tables migration)
//
// Composite PK (id, ts). Partitioned RANGE COLUMNS(ts).
// Prisma cannot emit PARTITION BY; Prisma's CREATE TABLE is dropped and
// re-issued in the partition migration. INSERT-only at the grant level.
// =============================================================================

enum AuditActorKind {
  user
  system
  worker
  external_api
}

model AuditLog {
  id          BigInt         @default(autoincrement())
  tenantId    BigInt         @default(1) @map("tenant_id")
  actorUserId BigInt?        @map("actor_user_id")
  actorKind   AuditActorKind @default(user) @map("actor_kind")
  action      String         @db.VarChar(64)
  entityType  String         @map("entity_type") @db.VarChar(32)
  entityId    String?        @map("entity_id") @db.VarChar(64)
  beforeJson  Json?          @map("before_json")
  afterJson   Json?          @map("after_json")
  requestId   String?        @map("request_id") @db.VarChar(64)
  ipAddress   String?        @map("ip_address") @db.VarChar(45)
  userAgent   String?        @map("user_agent") @db.VarChar(255)
  ts          DateTime       @db.DateTime(6)
  createdAt   DateTime       @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt   DateTime       @default(now()) @map("updated_at") @db.DateTime(6)
  // C03 chain columns — populated by audit_log_hash_chain BEFORE INSERT trigger
  prevHash    String         @default("") @map("prev_hash") @db.Char(64)
  rowHash     String         @default("") @map("row_hash") @db.Char(64)
  hashAt      DateTime       @default(now()) @map("hash_at") @db.DateTime(6)

  @@id([id, ts])
  @@index([tenantId, actorUserId, ts], map: "idx_audit_t_actor_ts")
  @@index([tenantId, entityType, entityId, ts], map: "idx_audit_t_entity_ts")
  @@index([tenantId, action, ts], map: "idx_audit_t_action_ts")
  @@index([tenantId, hashAt], map: "idx_audit_t_hash_at")
  @@map("audit_log")
}

// =============================================================================
// 4.6  campaigns   (composite PK tenant_id, id)
// =============================================================================

enum DialMethod {
  MANUAL
  RATIO
  PROGRESSIVE
  ADAPT_HARD
  ADAPT_AVG
  ADAPT_TAPERED
}

enum NextAgentCall {
  longest_wait
  random
  fewest_calls
  rank
}

// E04 amendment — agent-selection strategy for PROGRESSIVE dial (mirrors NextAgentCall;
// kept separate so E04 picker code stays decoupled from the legacy Vicidial field).
enum CallStrategy {
  longest_wait
  random
  fewest_calls
  rank
}

enum RecordingMode {
  NEVER
  ONDEMAND
  ALL
  ALLFORCE
}

enum AmdAction {
  drop
  vmdrop
  agent
}

enum PauseCodesRequired {
  OFF
  OPTIONAL
  FORCE
}

// C01 amendment — per-campaign policy when TZ resolution returns NONE.
enum UnknownTzPolicy {
  deny
  warn_pass
}

// E01 amendment — multi-list ordering / mixing strategy.
enum MultiListMix {
  EVEN
  MULTI
  NONE
}

// D06 amendment D06.A1 — what to do when a CALLBK lead is dialed and not answered.
enum CallbackNoAnswerPolicy {
  leave_callbk
  reschedule_24h
  terminate_NA
}

model Campaign {
  tenantId               BigInt             @default(1) @map("tenant_id")
  id                     String             @db.VarChar(32)
  name                   String             @db.VarChar(128)
  active                 Boolean            @default(true)
  dialMethod             DialMethod         @default(MANUAL) @map("dial_method")
  autoDialLevel          Decimal            @default(0.00) @map("auto_dial_level") @db.Decimal(4, 2)
  adaptiveMaxLevel       Decimal            @default(3.00) @map("adaptive_max_level") @db.Decimal(4, 2)
  // E05 amendment: renamed adaptive_drop_pct → drop_target_max; FCC hard ceiling 3.00% enforced by CHECK constraint.
  dropTargetMax          Decimal            @default(1.50) @map("drop_target_max") @db.Decimal(4, 2)
  dialTimeoutSec         Int                @default(22) @map("dial_timeout_sec") @db.SmallInt
  wrapupSeconds          Int                @default(10) @map("wrapup_seconds") @db.SmallInt
  nextAgentCall          NextAgentCall      @default(longest_wait) @map("next_agent_call")
  availableOnlyTally     Boolean            @default(false) @map("available_only_tally")
  hopperSizeTarget       Int                @default(0) @map("hopper_size_target")
  hopperMultiplier       Decimal            @default(2.0) @map("hopper_multiplier") @db.Decimal(3, 1)
  callerIdCarrierId      BigInt?            @map("caller_id_carrier_id")
  callerIdOverride       String?            @map("caller_id_override") @db.VarChar(16)
  recordingMode          RecordingMode      @default(ALL) @map("recording_mode")
  amdEnabled             Boolean            @default(false) @map("amd_enabled")
  amdAction              AmdAction          @default(drop) @map("amd_action")
  vmdropAudio            String?            @map("vmdrop_audio") @db.VarChar(255)
  safeHarborAudio        String?            @map("safe_harbor_audio") @db.VarChar(255)
  scriptId               BigInt?            @map("script_id")
  webformUrl             String?            @map("webform_url") @db.VarChar(512)
  dialStatusFilter       Json               @map("dial_status_filter")
  callTimeId             BigInt?            @map("call_time_id")
  useInternalDnc         Boolean            @default(true) @map("use_internal_dnc")
  useFederalDnc          Boolean            @default(true) @map("use_federal_dnc")
  useStateDnc            Boolean            @default(true) @map("use_state_dnc")
  pauseCodesRequired     PauseCodesRequired @default(OPTIONAL) @map("pause_codes_required")
  hotKeysActive          Boolean            @default(true) @map("hot_keys_active")
  closerIngroups         Json               @map("closer_ingroups")
  // C01 amendment §8.3 — per-campaign unknown-TZ policy (deny | warn_pass).
  unknownTzPolicy        UnknownTzPolicy    @default(deny) @map("unknown_tz_policy")
  // E01 amendment §10 — 16 hopper / pacing tunables (additive).
  dialLevel              Decimal            @default(1.50) @map("dial_level") @db.Decimal(4, 2)
  lockTtlSec             Int                @default(30) @map("lock_ttl_sec") @db.SmallInt
  minHopperLevel         Int                @default(50) @map("min_hopper_level")
  maxHopperLevel         Int                @default(5000) @map("max_hopper_level")
  hopperBufferMultiplier Decimal            @default(1.5) @map("hopper_buffer_multiplier") @db.Decimal(3, 1)
  recycleDelaySeconds    Int                @default(600) @map("recycle_delay_seconds")
  maxCallsPerLead        Int                @default(5) @map("max_calls_per_lead") @db.TinyInt
  dialStatuses           Json               @map("dial_statuses")
  lowWaterPct            Int                @default(25) @map("low_water_pct") @db.TinyInt
  highWaterPct           Int                @default(90) @map("high_water_pct") @db.TinyInt
  overFetchRatio         Decimal            @default(1.5) @map("over_fetch_ratio") @db.Decimal(3, 1)
  machineTerminal        Boolean            @default(true) @map("machine_terminal")
  leadFilterSql          String?            @map("lead_filter_sql") @db.Text
  multiListMix           MultiListMix       @default(EVEN) @map("multi_list_mix")
  // C02 amendment §9.3 — per-campaign consent policy (stricter-of with tenant minimum).
  // nil = use tenant's consent_minimum_mode; set to REQUIRE_ACTIVE for high-risk.
  consentPolicyOverride  ConsentMode?       @map("consent_policy_override")
  // C02 amendment §9.3 — why calls are recorded (PA §5704(15) B2B carve-out gate).
  recordingPurpose       RecordingPurpose   @default(general) @map("recording_purpose")
  // C02 amendment §9.3 — what to do when customer declines REQUIRE_ACTIVE consent.
  optOutAction           OptOutAction       @default(continue_no_record) @map("opt_out_action")
  // C02 amendment §9.3 — FS-local path to consent audio played before bridge.
  // nil = system default (freeswitch/sounds/consent/default/en-US/vici2_consent_msg.wav).
  consentMsgAudio        String?            @map("consent_msg_audio") @db.VarChar(255)
  // E02 amendment A2/E02 §11 — four pacing-engine tunables (additive).
  // calls_per_second: token-bucket CPS ceiling for E04 dispatch.
  callsPerSecond         Int                @default(5) @map("calls_per_second") @db.UnsignedSmallInt
  // ramp_up_factor: multiplier for ramp_up_rate_clamp; prevents wake-up storms.
  rampUpFactor           Decimal            @default(2.00) @map("ramp_up_factor") @db.Decimal(4, 2)
  // min_call_buffer_seconds: FCC 2-s safe-harbor clamp for min_call_buffer.
  minCallBufferSeconds   Decimal            @default(2.00) @map("min_call_buffer_seconds") @db.Decimal(4, 2)
  // pacing_tick_ms: per-campaign tick interval [200,5000]. Default 1000 ms (1 Hz).
  pacingTickMs           Int                @default(1000) @map("pacing_tick_ms") @db.UnsignedSmallInt
  // E04 amendment §3.3 — fence-token TTL for double-dial prevention.
  // Distinct from lock_ttl_sec (hopper-lock). Default 30 s = T04 pipeline (~10 ms)
  // + T01 ESL roundtrip (~50 ms) + ring timeout (22 s) + 7 s safety margin.
  leadLockTtlSeconds     Int                @default(30) @map("lead_lock_ttl_seconds")
  // E04 amendment §3.3 — agent-selection strategy for PROGRESSIVE dial.
  // Phase 3 ships random/fewest_calls/rank; today only longest_wait is implemented.
  callStrategy           CallStrategy       @default(longest_wait) @map("call_strategy")
  // E03 amendment §9.1 — 9 adaptive engine columns (FROZEN).
  adaptiveIntensity      Int                @default(0) @map("adaptive_intensity") @db.TinyInt
  adaptiveDlDiffTarget   Int                @default(-1) @map("adaptive_dl_diff_target") @db.TinyInt
  adaptTickSeconds       Int                @default(15) @map("adapt_tick_seconds") @db.UnsignedSmallInt
  holdBandPp             Decimal            @default(0.30) @map("hold_band_pp") @db.Decimal(3, 2)
  warmupMinAnswered      Int                @default(50) @map("warmup_min_answered") @db.UnsignedSmallInt
  warmupMinSeconds       Int                @default(300) @map("warmup_min_seconds") @db.UnsignedSmallInt
  dropGatedDebounceSec   Int                @default(30) @map("drop_gated_debounce_sec") @db.UnsignedSmallInt
  shiftStartLocal        DateTime?          @map("shift_start_local") @db.Time
  shiftEndLocal          DateTime?          @map("shift_end_local") @db.Time
  // E05 amendment §9.1 — drop-gate threshold pair + dwell + counting policy.
  dropTargetSoft         Decimal            @default(1.00) @map("drop_target_soft") @db.Decimal(4, 2)
  dropTargetMaxOverride  Decimal?           @map("drop_target_max_override") @db.Decimal(4, 2)
  recoverSeconds         Int                @default(300) @map("recover_seconds")
  countEarlyCustomerHangupAsDrop Boolean    @default(true) @map("count_early_customer_hangup_as_drop")
  // D06 amendments D06.A1/A2/A3 — callback scheduler tunables.
  callbackNoAnswerPolicy        CallbackNoAnswerPolicy @default(leave_callbk) @map("callback_no_answer_policy")
  callbackGraceWindowSeconds    Int                    @default(30) @map("callback_grace_window_seconds")
  callbackStaleThresholdSeconds Int                    @default(14400) @map("callback_stale_threshold_seconds")
  createdAt              DateTime           @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt              DateTime           @updatedAt @map("updated_at") @db.DateTime(6)

  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_campaigns_tenant")
  callerIdCarrier Carrier?                 @relation("CampaignCallerCarrier", fields: [callerIdCarrierId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_campaigns_caller_carrier")
  script          Script?                  @relation(fields: [scriptId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_campaigns_script")
  callTime        CallTime?                @relation(fields: [callTimeId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_campaigns_calltime")
  campaignLists   CampaignList[]
  pauseCodes      PauseCode[]
  scripts         Script[]                 @relation("ScriptCampaign")
  callbacks       Callback[]
  hopperMirror    HopperMirror[]
  dispositions    Disposition[]
  statusOverrides CampaignStatusOverride[]

  @@id([tenantId, id])
  @@index([tenantId, active, dialMethod], map: "idx_campaigns_t_active_method")
  @@map("campaigns")
}

// =============================================================================
// E01 amendment §10/§12 — campaign_status_overrides
//
// Per-campaign override of `statuses.recycle_delay_seconds` (the column lives
// on D04's statuses table; this table allows the value to differ per campaign
// without touching the system-wide row).
// =============================================================================

model CampaignStatusOverride {
  tenantId            BigInt   @default(1) @map("tenant_id")
  campaignId          String   @map("campaign_id") @db.VarChar(32)
  statusCode          String   @map("status_code") @db.VarChar(8)
  recycleDelaySeconds Int?     @map("recycle_delay_seconds")
  maxCalls            Int?     @map("max_calls") @db.TinyInt
  notes               String?  @db.VarChar(255)
  createdAt           DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.DateTime(6)

  campaign Campaign @relation(fields: [tenantId, campaignId], references: [tenantId, id], onDelete: Cascade, onUpdate: NoAction, map: "fk_camp_status_ovr_campaign")

  @@id([tenantId, campaignId, statusCode])
  @@index([tenantId, statusCode], map: "idx_camp_status_ovr_t_status")
  @@map("campaign_status_overrides")
}

// =============================================================================
// 4.7  lists
// =============================================================================

model List {
  id               BigInt    @id @default(autoincrement())
  tenantId         BigInt    @default(1) @map("tenant_id")
  name             String    @db.VarChar(128)
  description      String?   @db.Text
  active           Boolean   @default(true)
  resetTime        DateTime? @map("reset_time") @db.Time(0)
  expiration       DateTime? @db.Date
  source           String?   @db.VarChar(64)
  // T04 amendment — per-list caller-ID waterfall tier 2 (overrides campaign).
  callerIdOverride String?   @map("caller_id_override") @db.VarChar(16)
  callerIdName     String?   @map("caller_id_name") @db.VarChar(32)
  // D02 amendment §4.3 — column-mapping snapshot persisted per list.
  columnMapping    Json?     @map("column_mapping")
  createdAt        DateTime  @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.DateTime(6)

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_lists_tenant")
  campaignLists CampaignList[]
  leads         Lead[]
  imports       Import[]

  @@unique([tenantId, name], map: "uk_lists_tenant_name")
  @@index([tenantId, active], map: "idx_lists_t_active")
  @@map("lists")
}

// =============================================================================
// 4.8  campaign_lists
// =============================================================================

model CampaignList {
  tenantId   BigInt   @default(1) @map("tenant_id")
  campaignId String   @map("campaign_id") @db.VarChar(32)
  listId     BigInt   @map("list_id")
  priority   Int      @default(0) @db.SmallInt
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime(6)

  campaign Campaign @relation(fields: [tenantId, campaignId], references: [tenantId, id], onDelete: Cascade, onUpdate: NoAction, map: "fk_camp_lists_campaign")
  list     List     @relation(fields: [listId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_camp_lists_list")

  @@id([tenantId, campaignId, listId])
  @@index([tenantId, listId], map: "idx_camp_lists_t_list")
  @@map("campaign_lists")
}

// =============================================================================
// 4.9  statuses (per-campaign or system default with __SYS__ sentinel)
// =============================================================================

model Status {
  tenantId             BigInt   @default(1) @map("tenant_id")
  campaignId           String   @map("campaign_id") @db.VarChar(32)
  // D04 amendment: widened from VARCHAR(8) to VARCHAR(24) for GATEWAY_LIMIT_TRY_LATER
  status               String   @db.VarChar(24)
  description          String   @default("") @db.VarChar(128)
  selectable           Boolean  @default(true)
  humanAnswered        Boolean  @default(false) @map("human_answered")
  sale                 Boolean  @default(false)
  dnc                  Boolean  @default(false)
  callback             Boolean  @default(false)
  notInterested        Boolean  @default(false) @map("not_interested")
  hotkey               String?  @db.Char(1)
  // D04 amendment: recycle-delay semantics (NULL=campaign default, 0=immediate, -1=terminal, >0=seconds)
  recycleDelaySeconds  Int?     @map("recycle_delay_seconds")
  // D04 amendment: status taxonomy category
  category             String?  @db.VarChar(20)
  // D04 amendment: which module emits this status
  systemOwner          String?  @map("system_owner") @db.VarChar(8)
  createdAt            DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.DateTime(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_statuses_tenant")
  // Note: no DB-level FK to campaigns because the __SYS__ sentinel does not
  // exist in `campaigns`. App-layer enforces "real" campaign rows.

  @@id([tenantId, campaignId, status])
  @@map("statuses")
}

// =============================================================================
// 4.10  pause_codes
// =============================================================================

model PauseCode {
  id         BigInt   @id @default(autoincrement())
  tenantId   BigInt   @default(1) @map("tenant_id")
  campaignId String?  @map("campaign_id") @db.VarChar(32)
  code       String   @db.VarChar(16)
  name       String   @db.VarChar(64)
  billable   Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.DateTime(6)

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_pause_codes_tenant")
  campaign Campaign? @relation(fields: [tenantId, campaignId], references: [tenantId, id], onDelete: Cascade, onUpdate: NoAction, map: "fk_pause_codes_campaign")

  // Functional UNIQUE coalesced campaign_id added in extra-indexes migration:
  //   UNIQUE (tenant_id, IFNULL(campaign_id,'__SYS__'), code)
  @@index([tenantId, campaignId, code], map: "idx_pause_codes_t_camp_code")
  @@map("pause_codes")
}

// =============================================================================
// 4.11  scripts
// =============================================================================

model Script {
  id         BigInt   @id @default(autoincrement())
  tenantId   BigInt   @default(1) @map("tenant_id")
  name       String   @db.VarChar(64)
  body       String   @db.MediumText
  campaignId String?  @map("campaign_id") @db.VarChar(32)
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.DateTime(6)

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_scripts_tenant")
  campaign  Campaign?  @relation("ScriptCampaign", fields: [tenantId, campaignId], references: [tenantId, id], onDelete: NoAction, onUpdate: NoAction, map: "fk_scripts_campaign")
  campaigns Campaign[] // back-relation for campaigns.scriptId

  @@index([tenantId, campaignId], map: "idx_scripts_t_camp")
  @@map("scripts")
}

// =============================================================================
// 4.12  call_times
// =============================================================================

model CallTime {
  id             BigInt   @id @default(autoincrement())
  tenantId       BigInt   @default(1) @map("tenant_id")
  name           String   @db.VarChar(64)
  defaultStart   DateTime @default(dbgenerated("'09:00:00'")) @map("default_start") @db.Time(0)
  defaultEnd     DateTime @default(dbgenerated("'21:00:00'")) @map("default_end") @db.Time(0)
  stateOverrides Json     @map("state_overrides")
  createdAt      DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.DateTime(6)

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_call_times_tenant")
  campaigns Campaign[]

  @@unique([tenantId, name], map: "uk_call_times_tenant_name")
  @@map("call_times")
}

// =============================================================================
// 4.13  leads  (the heart)
// =============================================================================

enum Gender {
  M
  F
  U
}

model Lead {
  id                BigInt    @id @default(autoincrement())
  tenantId          BigInt    @default(1) @map("tenant_id")
  listId            BigInt    @map("list_id")
  status            String    @default("NEW") @db.VarChar(8)
  vendorLeadCode    String?   @map("vendor_lead_code") @db.VarChar(64)
  sourceId          String?   @map("source_id") @db.VarChar(64)
  phoneE164         String    @map("phone_e164") @db.VarChar(16)
  phoneAlt          String?   @map("phone_alt") @db.VarChar(16)
  phoneAlt2         String?   @map("phone_alt2") @db.VarChar(16)
  countryCode       String    @default("US") @map("country_code") @db.Char(2)
  title             String?   @db.VarChar(8)
  firstName         String?   @map("first_name") @db.VarChar(64)
  middleInitial     String?   @map("middle_initial") @db.VarChar(4)
  lastName          String?   @map("last_name") @db.VarChar(64)
  address1          String?   @db.VarChar(128)
  address2          String?   @db.VarChar(128)
  city              String?   @db.VarChar(64)
  state             String?   @db.Char(2)
  postalCode        String?   @map("postal_code") @db.VarChar(16)
  email             String?   @db.VarChar(128)
  dateOfBirth       DateTime? @map("date_of_birth") @db.Date
  gender            Gender    @default(U)
  comments          String?   @db.Text
  rank              Int       @default(0)
  ownerUserId       BigInt?   @map("owner_user_id")
  customData        Json      @map("custom_data")
  calledCount       Int       @default(0) @map("called_count")
  lastCalledAt      DateTime? @map("last_called_at") @db.DateTime(6)
  lastLocalCallTime DateTime? @map("last_local_call_time") @db.Time(0)
  tzOffsetMin       Int?      @map("tz_offset_min") @db.SmallInt
  knownTimezone     String?   @map("known_timezone") @db.VarChar(40)
  // C01 amendment §8.4 — surface BLOCK_INVALID(no_timezone) leads to M03.
  tzBlocked         Boolean   @default(false) @map("tz_blocked")
  // C02 amendment §9.4 — PA §5704(15) B2B carve-out gate; populated by D01 CSV import.
  isBusiness        Boolean   @default(false) @map("is_business")
  // D01 amendment §13.1 — optimistic-lock token for /api/leads PATCH (If-Match).
  version           Int       @default(1) @db.SmallInt
  deletedAt         DateTime? @map("deleted_at") @db.DateTime(6)
  entryAt           DateTime  @default(now()) @map("entry_at") @db.DateTime(6)
  modifyAt          DateTime  @default(now()) @map("modify_at") @db.DateTime(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.DateTime(6)

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_leads_tenant")
  list         List           @relation(fields: [listId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_leads_list")
  ownerUser    User?          @relation(fields: [ownerUserId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_leads_owner")
  callbacks    Callback[]
  hopper       HopperMirror[]
  dispositions Disposition[]

  @@index([tenantId, listId, status, modifyAt], map: "idx_leads_t_list_status_modify")
  @@index([tenantId, phoneE164], map: "idx_leads_t_phone")
  @@index([tenantId, status, modifyAt], map: "idx_leads_t_status_modify")
  @@index([tenantId, ownerUserId, status], map: "idx_leads_t_owner_status")
  @@index([tenantId, calledCount], map: "idx_leads_t_called_count")
  @@index([tenantId, state], map: "idx_leads_t_state")
  @@index([tenantId, postalCode], map: "idx_leads_t_postal")
  @@index([tenantId, vendorLeadCode], map: "idx_leads_t_vendor")
  @@index([tenantId, deletedAt], map: "idx_leads_t_deleted")
  @@map("leads")
}

// =============================================================================
// 4.14  dnc
// =============================================================================

enum DncSource {
  federal
  state
  internal
  litigator
  reassigned
}

model Dnc {
  tenantId   BigInt    @default(1) @map("tenant_id")
  phoneE164  String    @map("phone_e164") @db.VarChar(16)
  source     DncSource
  state      String    @default("__") @db.Char(2)
  campaignId String    @default("__GLOBAL__") @map("campaign_id") @db.VarChar(32)
  addedAt    DateTime  @default(now()) @map("added_at") @db.DateTime(6)
  addedBy    BigInt?   @map("added_by")
  expiresAt  DateTime? @map("expires_at") @db.DateTime(6)
  notes      String?   @db.VarChar(255)
  createdAt  DateTime  @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.DateTime(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_dnc_tenant")

  @@id([tenantId, phoneE164, source, state, campaignId])
  @@index([phoneE164], map: "idx_dnc_phone_only")
  @@index([tenantId, source, addedAt], map: "idx_dnc_t_source_added")
  @@map("dnc")
}

// =============================================================================
// 4.15  phone_codes  (A1 amendment: NPA + NXX granularity)
//                   No tenant_id (sole exception — global NANP reference)
// =============================================================================

enum PhoneCodeConfidence {
  NPA
  NXX
}

model PhoneCode {
  areaCode     String              @map("area_code") @db.Char(3)
  exchangeCode String              @map("exchange_code") @db.Char(3)
  state        String?             @db.Char(2)
  county       String?             @db.VarChar(64)
  tzIana       String              @map("tz_iana") @db.VarChar(40)
  confidence   PhoneCodeConfidence @default(NXX)
  createdAt    DateTime            @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.DateTime(6)

  @@id([areaCode, exchangeCode])
  @@index([state], map: "idx_phone_codes_state")
  @@index([tzIana], map: "idx_phone_codes_tz")
  @@map("phone_codes")
}

// =============================================================================
// A5  phone_codes_overrides  (manual override resolver per D03)
//     Same shape as phone_codes plus reason / created_by / created_at.
// =============================================================================

model PhoneCodeOverride {
  areaCode        String              @map("area_code") @db.Char(3)
  exchangeCode    String              @map("exchange_code") @db.Char(3)
  state           String?             @db.Char(2)
  county          String?             @db.VarChar(64)
  tzIana          String              @map("tz_iana") @db.VarChar(40)
  confidence      PhoneCodeConfidence @default(NXX)
  reason          String?             @db.VarChar(255)
  createdAt       DateTime            @default(now()) @map("created_at") @db.DateTime(6)
  createdByUserId BigInt?             @map("created_by_user_id")

  @@id([areaCode, exchangeCode])
  @@index([state], map: "idx_phone_overrides_state")
  @@map("phone_codes_overrides")
}

// =============================================================================
// A4  zip_codes  (D03 ZIP → IANA cascade tier 2)
//                No tenant_id (global reference)
// =============================================================================

enum ZipConfidence {
  ZIP
}

model ZipCode {
  zip        String        @id @db.Char(5)
  tzIana     String        @map("tz_iana") @db.VarChar(40)
  state      String?       @db.Char(2)
  confidence ZipConfidence @default(ZIP)

  @@index([state], map: "idx_zip_codes_state")
  @@index([tzIana], map: "idx_zip_codes_tz")
  @@map("zip_codes")
}

// =============================================================================
// 4.16  callbacks
// =============================================================================

enum CallbackStatus {
  LIVE
  PENDING
  DONE
  DEAD
}

model Callback {
  id         BigInt         @id @default(autoincrement())
  tenantId   BigInt         @default(1) @map("tenant_id")
  leadId     BigInt         @map("lead_id")
  campaignId String         @map("campaign_id") @db.VarChar(32)
  userId     BigInt?        @map("user_id")
  callbackAt DateTime       @map("callback_at") @db.DateTime(6)
  comments   String?        @db.Text
  status     CallbackStatus @default(PENDING)
  createdBy  BigInt?        @map("created_by")
  createdAt  DateTime       @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt  DateTime       @updatedAt @map("updated_at") @db.DateTime(6)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_callbacks_tenant")
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_callbacks_lead")
  campaign Campaign @relation(fields: [tenantId, campaignId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction, map: "fk_callbacks_campaign")
  user     User?    @relation("CallbacksOwner", fields: [userId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_callbacks_user")
  creator  User?    @relation("CallbacksCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_callbacks_creator")

  @@index([tenantId, status, callbackAt], map: "idx_callbacks_t_status_due")
  @@index([tenantId, userId, callbackAt], map: "idx_callbacks_t_user_due")
  @@index([tenantId, leadId], map: "idx_callbacks_t_lead")
  @@map("callbacks")
}

// =============================================================================
// 4.17  hopper_mirror
// =============================================================================

model HopperMirror {
  id           BigInt    @id @default(autoincrement())
  tenantId     BigInt    @default(1) @map("tenant_id")
  campaignId   String    @map("campaign_id") @db.VarChar(32)
  leadId       BigInt    @map("lead_id")
  priority     Int       @default(0)
  scheduledAt  DateTime  @map("scheduled_at") @db.DateTime(6)
  claimedBy    String?   @map("claimed_by") @db.VarChar(64)
  claimedUntil DateTime? @map("claimed_until") @db.DateTime(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.DateTime(6)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_hopper_tenant")
  campaign Campaign @relation(fields: [tenantId, campaignId], references: [tenantId, id], onDelete: Cascade, onUpdate: NoAction, map: "fk_hopper_campaign")
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_hopper_lead")

  @@unique([tenantId, campaignId, leadId], map: "uk_hopper_t_camp_lead")
  @@index([tenantId, campaignId, scheduledAt], map: "idx_hopper_t_camp_scheduled")
  @@map("hopper_mirror")
}

// =============================================================================
// 4.18  recordings  (lifecycle / sharing — non-partitioned counterpart)
// =============================================================================

enum RecordingLifecycle {
  encoding
  available
  archived
  deleted
}

model Recording {
  id                  BigInt             @id @default(autoincrement())
  tenantId            BigInt             @default(1) @map("tenant_id")
  recordingLogId      BigInt             @map("recording_log_id")
  shareToken          Bytes?             @unique(map: "uk_recordings_share_token") @map("share_token") @db.Binary(16)
  shareTokenExpiresAt DateTime?          @map("share_token_expires_at") @db.DateTime(6)
  legalHold           Boolean            @default(false) @map("legal_hold")
  lifecycleState      RecordingLifecycle @default(encoding) @map("lifecycle_state")
  s3StorageClass      String?            @map("s3_storage_class") @db.VarChar(32)
  // R02 amendment §6.2 — two-phase delete flag: TRUE after upload+verify; sweeper clears after fs.unlink
  deletionPending     Boolean            @default(false) @map("deletion_pending")
  createdAt           DateTime           @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt           DateTime           @updatedAt @map("updated_at") @db.DateTime(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_recordings_tenant")

  @@index([tenantId, lifecycleState], map: "idx_recordings_t_lifecycle")
  // R02 sweeper index: filter on deletion_pending + lifecycle_state + updated_at
  @@index([tenantId, deletionPending, lifecycleState, updatedAt], map: "idx_recordings_sweep")
  @@map("recordings")
}

// =============================================================================
// 4.19  dispositions
// =============================================================================

model Disposition {
  id         BigInt   @id @default(autoincrement())
  tenantId   BigInt   @default(1) @map("tenant_id")
  callLogId  BigInt   @map("call_log_id")
  leadId     BigInt   @map("lead_id")
  campaignId String   @map("campaign_id") @db.VarChar(32)
  userId     BigInt?  @map("user_id")
  statusCode String   @map("status_code") @db.VarChar(8)
  comments   String?  @db.Text
  disposedAt DateTime @map("disposed_at") @db.DateTime(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.DateTime(6)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_disp_tenant")
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_disp_lead")
  campaign Campaign @relation(fields: [tenantId, campaignId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction, map: "fk_disp_campaign")
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_disp_user")

  @@index([tenantId, leadId, disposedAt], map: "idx_disp_t_lead_disposed")
  @@index([tenantId, campaignId, disposedAt], map: "idx_disp_t_camp_disposed")
  @@map("dispositions")
}

// =============================================================================
// 4.20  carriers
// =============================================================================

enum CarrierKind {
  twilio
  telnyx // legacy — retagged to telnyx-creds/-ip on T02 IMPLEMENT
  telnyx_creds @map("telnyx-creds")
  telnyx_ip    @map("telnyx-ip")
  signalwire
  ringcentral
  bandwidth
  flowroute
  byoc
}

model Carrier {
  id            BigInt      @id @default(autoincrement())
  tenantId      BigInt      @default(1) @map("tenant_id")
  name          String      @db.VarChar(64)
  kind          CarrierKind
  proxy         String      @db.VarChar(255)
  usernameCt    Bytes?      @map("username_ct") @db.VarBinary(512)
  passwordCt    Bytes?      @map("password_ct") @db.VarBinary(512)
  kekVersion    Int         @default(1) @map("kek_version") @db.SmallInt
  register      Boolean     @default(false)
  callerIdE164  String?     @map("caller_id_e164") @db.VarChar(16)
  active        Boolean     @default(true)
  ipAllowlist   Json        @map("ip_allowlist")
  configJson    Json        @map("config_json")
  // T02 amendment §14.5 — extra columns (additive).
  sendPai       Boolean     @default(false) @map("send_pai")
  isEmergency   Boolean     @default(false) @map("is_emergency")
  maxConcurrent Int?        @map("max_concurrent")
