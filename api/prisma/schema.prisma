// =============================================================================
// 4.20  carriers
// =============================================================================

enum CarrierKind {
  twilio
  telnyx // legacy — retagged to telnyx-creds/-ip on T02 IMPLEMENT
  telnyx_creds @map("telnyx-creds")
  telnyx_ip    @map("telnyx-ip")
  signalwire
  ringcentral
  bandwidth
  flowroute
  byoc
}

model Carrier {
  id            BigInt      @id @default(autoincrement())
  tenantId      BigInt      @default(1) @map("tenant_id")
  name          String      @db.VarChar(64)
  kind          CarrierKind
  proxy         String      @db.VarChar(255)
  usernameCt    Bytes?      @map("username_ct") @db.VarBinary(512)
  passwordCt    Bytes?      @map("password_ct") @db.VarBinary(512)
  kekVersion    Int         @default(1) @map("kek_version") @db.SmallInt
  register      Boolean     @default(false)
  callerIdE164  String?     @map("caller_id_e164") @db.VarChar(16)
  active        Boolean     @default(true)
  ipAllowlist   Json        @map("ip_allowlist")
  configJson    Json        @map("config_json")
  // T02 amendment §14.5 — extra columns (additive).
  sendPai       Boolean     @default(false) @map("send_pai")
  isEmergency   Boolean     @default(false) @map("is_emergency")
  maxConcurrent Int?        @map("max_concurrent")
  notes         Json        @map("notes")
  version       Int         @default(1)
  createdAt     DateTime    @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.DateTime(6)

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_carriers_tenant")
  gateways   Gateway[]
  didNumbers DidNumber[]
  campaigns  Campaign[]  @relation("CampaignCallerCarrier")

  @@unique([tenantId, name], map: "uk_carriers_tenant_name")
  @@index([tenantId, active], map: "idx_carriers_t_active")
  @@map("carriers")
}

// =============================================================================
// 4.21  gateways
// =============================================================================

enum GatewayTransport {
  udp
  tcp
  tls
}

model Gateway {
  id                BigInt           @id @default(autoincrement())
  tenantId          BigInt           @default(1) @map("tenant_id")
  carrierId         BigInt           @map("carrier_id")
  name              String           @db.VarChar(64)
  proxy             String           @db.VarChar(255)
  realm             String?          @db.VarChar(255)
  fromUser          String?          @map("from_user") @db.VarChar(64)
  fromDomain        String?          @map("from_domain") @db.VarChar(255)
  extension         String?          @db.VarChar(64)
  register          Boolean          @default(false)
  expireSeconds     Int              @default(3600) @map("expire_seconds")
  retrySeconds      Int              @default(30) @map("retry_seconds")
  transport         GatewayTransport @default(udp)
  priority          Int              @default(100) @db.SmallInt
  active            Boolean          @default(true)
  templateOverrides Json             @map("template_overrides")
  // T02 amendment §14.5 — distributor weight + concurrency cap + version + cost.
  weight            Int              @default(100) @db.SmallInt
  maxConcurrent     Int?             @map("max_concurrent")
  version           Int              @default(1)
  costPerMinCents   Int?             @map("cost_per_min_cents")
  createdAt         DateTime         @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.DateTime(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_gateways_tenant")
  carrier Carrier @relation(fields: [carrierId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_gateways_carrier")

  @@unique([tenantId, name], map: "uk_gateways_tenant_name")
  @@index([tenantId, carrierId, active, priority], map: "idx_gateways_t_carrier_active_pri")
  @@map("gateways")
}

// =============================================================================
// 4.22  did_numbers
