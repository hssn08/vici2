  @@map("call_times")
}

// =============================================================================
// 4.13  leads  (the heart)
// =============================================================================

enum Gender {
  M
  F
  U
}

model Lead {
  id                BigInt    @id @default(autoincrement())
  tenantId          BigInt    @default(1) @map("tenant_id")
  listId            BigInt    @map("list_id")
  status            String    @default("NEW") @db.VarChar(8)
  vendorLeadCode    String?   @map("vendor_lead_code") @db.VarChar(64)
  sourceId          String?   @map("source_id") @db.VarChar(64)
  phoneE164         String    @map("phone_e164") @db.VarChar(16)
  phoneAlt          String?   @map("phone_alt") @db.VarChar(16)
  phoneAlt2         String?   @map("phone_alt2") @db.VarChar(16)
  countryCode       String    @default("US") @map("country_code") @db.Char(2)
  title             String?   @db.VarChar(8)
  firstName         String?   @map("first_name") @db.VarChar(64)
  middleInitial     String?   @map("middle_initial") @db.VarChar(4)
  lastName          String?   @map("last_name") @db.VarChar(64)
  address1          String?   @db.VarChar(128)
  address2          String?   @db.VarChar(128)
  city              String?   @db.VarChar(64)
  state             String?   @db.Char(2)
  postalCode        String?   @map("postal_code") @db.VarChar(16)
  email             String?   @db.VarChar(128)
  dateOfBirth       DateTime? @map("date_of_birth") @db.Date
  gender            Gender    @default(U)
  comments          String?   @db.Text
  rank              Int       @default(0)
  ownerUserId       BigInt?   @map("owner_user_id")
  customData        Json      @map("custom_data")
  calledCount       Int       @default(0) @map("called_count")
  lastCalledAt      DateTime? @map("last_called_at") @db.DateTime(6)
  lastLocalCallTime DateTime? @map("last_local_call_time") @db.Time(0)
  tzOffsetMin       Int?      @map("tz_offset_min") @db.SmallInt
  knownTimezone     String?   @map("known_timezone") @db.VarChar(40)
  // C01 amendment §8.4 — surface BLOCK_INVALID(no_timezone) leads to M03.
  tzBlocked         Boolean   @default(false) @map("tz_blocked")
  // D01 amendment §13.1 — optimistic-lock token for /api/leads PATCH (If-Match).
  version           Int       @default(1) @db.SmallInt
  deletedAt         DateTime? @map("deleted_at") @db.DateTime(6)
  entryAt           DateTime  @default(now()) @map("entry_at") @db.DateTime(6)
  modifyAt          DateTime  @default(now()) @map("modify_at") @db.DateTime(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.DateTime(6)

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_leads_tenant")
  list         List           @relation(fields: [listId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_leads_list")
  ownerUser    User?          @relation(fields: [ownerUserId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_leads_owner")
  callbacks    Callback[]
  hopper       HopperMirror[]
  dispositions Disposition[]

  @@index([tenantId, listId, status, modifyAt], map: "idx_leads_t_list_status_modify")
  @@index([tenantId, phoneE164], map: "idx_leads_t_phone")
  @@index([tenantId, status, modifyAt], map: "idx_leads_t_status_modify")
  @@index([tenantId, ownerUserId, status], map: "idx_leads_t_owner_status")
  @@index([tenantId, calledCount], map: "idx_leads_t_called_count")
  @@index([tenantId, state], map: "idx_leads_t_state")
  @@index([tenantId, postalCode], map: "idx_leads_t_postal")
  @@index([tenantId, vendorLeadCode], map: "idx_leads_t_vendor")
  @@index([tenantId, deletedAt], map: "idx_leads_t_deleted")
  @@map("leads")
}

// =============================================================================
// 4.14  dnc
// =============================================================================

enum DncSource {
  federal
  state
  internal
  litigator
