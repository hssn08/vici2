// vici2 — F02 MySQL 8 schema (Prisma source of truth)
//
// Conventions (FROZEN per F02 PLAN §3):
//  - PK: BigInt auto-increment, except phone_codes / phone_codes_overrides /
//    zip_codes (NANP reference) and join tables with composite PKs.
//  - tenant_id: BigInt @default(1) on every table except the four global
//    reference tables noted above.
//  - Timestamps: DateTime(6) created_at / updated_at on every table.
//  - VARBINARY(512) ciphertext columns + kek_version SMALLINT for envelope
//    encryption (F05 owns the cipher).
//  - JSON columns are MySQL native JSON; Zod-validated in app code.
//  - Enums for fixed business vocabularies; lookup tables for vocabularies
//    that grow (statuses, pause_codes, audit_log.action / entity_type).
//  - Composite indexes lead with tenant_id (CI script enforces).
//
// Migrations FROZEN sequence (Prisma autogenerates timestamps; logical order):
//   0_init                 → all non-partitioned tables + audit_log model
//   1_partition_log_tables → drops Prisma-emitted CREATE TABLE for the 5
//                            log tables and re-creates with PARTITION BY
//                            RANGE COLUMNS (+3 months pre-creation)
//   2_drop_partition_fks   → drops any FK Prisma emitted for those tables
//   3_audit_grants         → creates vici2_app/backup/root + REVOKEs
//                            UPDATE/DELETE on audit_log from vici2_app
//
// Amendments applied (per orchestrator brief):
//   A1: phone_codes PK extended to (area_code, exchange_code) — NXX granular
//   A2: users.totp_required BOOLEAN DEFAULT false (F05 hook)
//   A3: auth_config single-row table (F05 hook)
//   A4: zip_codes table (D03 ZIP cascade)
//   A5: phone_codes_overrides (D03 manual override resolver)
//   A6: bootstrap super_admin shape (no row seeded — F05 owns)
//
// Wave-5 amendments (feat/F02-amendments — additive only, no DROP):
//   C01.1  call_window_audit table (partitioned, INSERT-only) — TCPA decisions log
//   C01.2  state_holidays table (admin-display lookup; non-partitioned)
//   C01.3  campaigns.unknown_tz_policy ENUM('deny','warn_pass') DEFAULT 'deny'
//   C01.4  leads.tz_blocked TINYINT(1) DEFAULT 0  (M03 admin-review flag)
//   T02.1  carriers.kind ENUM widened from 5 → 8 values (telnyx-creds/-ip,
//          bandwidth, flowroute added; legacy 'telnyx' kept for back-compat)
//   T02.2  carriers.send_pai BOOLEAN DEFAULT false  (per-call PAI default)
//   T02.3  carriers.is_emergency BOOLEAN DEFAULT false  (E911 tag)
//   T02.4  carriers.max_concurrent INT NULL  (carrier-wide concurrency cap)
//   T02.5  carriers.notes JSON NOT NULL DEFAULT (JSON_OBJECT())  (operator memos)
//   T02.6  carriers.version INT NOT NULL DEFAULT 1  (optimistic concurrency)
//   T02.7  gateways.weight SMALLINT NOT NULL DEFAULT 100  (Phase-2 distributor)
//   T02.8  gateways.max_concurrent INT NULL
//   T02.9  gateways.version INT NOT NULL DEFAULT 1
//   T02.10 gateways.cost_per_min_cents INT NULL  (Phase-2 forward-compat)
//   D01.1  leads.version SMALLINT NOT NULL DEFAULT 1  (optimistic-lock token)
//   D05.1  tenant_id=0 sentinel row supported by FK (seed insert id=0)
//   D05.2  dnc_sync_config table (per-source cadence + last/next_run_at)
//   D05.3  dnc_sync_log table (partitioned, INSERT-only) — sync run summaries
//   D05.4  tenants.internal_dnc_retention_years SMALLINT DEFAULT 5  (max 99)
//   E01.1  campaigns.dial_level DECIMAL(4,2) DEFAULT 1.50
//   E01.2  campaigns.dial_timeout_sec already exists; re-named not needed
//   E01.3  campaigns.lock_ttl_sec SMALLINT DEFAULT 30
//   E01.4  campaigns.min_hopper_level INT DEFAULT 50
//   E01.5  campaigns.max_hopper_level INT DEFAULT 5000
//   E01.6  campaigns.hopper_buffer_multiplier DECIMAL(3,1) DEFAULT 1.5
//   E01.7  campaigns.recycle_delay_seconds INT DEFAULT 600
//   E01.8  campaigns.max_calls_per_lead TINYINT DEFAULT 5
//   E01.9  campaigns.dial_statuses JSON DEFAULT (JSON_ARRAY('NEW','NA','B','CALLBK'))
//   E01.10 campaigns.low_water_pct TINYINT DEFAULT 25
//   E01.11 campaigns.high_water_pct TINYINT DEFAULT 90
//   E01.12 campaigns.over_fetch_ratio DECIMAL(3,1) DEFAULT 1.5
//   E01.13 campaigns.machine_terminal BOOL DEFAULT true
//   E01.14 campaigns.lead_filter_sql TEXT NULL
//   E01.15 campaigns.multi_list_mix ENUM('EVEN','MULTI','NONE') DEFAULT 'EVEN'
//   E01.16 campaign_status_overrides table (per-campaign status recycle override)
//   T04.1  originate_audit table (partitioned by originated_at; INSERT+UPDATE-once)
//   T04.2  4 new D04 statuses seeded: TCPA, CONSENT_NOT_OBTAINED,
//          CARRIER_FAIL, GATEWAY_LIMIT_TRY_LATER (under campaign_id='__SYS__')
//   T04.3  lists.caller_id_override VARCHAR(16) NULL
//   T04.4  lists.caller_id_name VARCHAR(32) NULL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// 4.1  tenants
// =============================================================================

model Tenant {
  id                        BigInt   @id @default(autoincrement())
  name                      String   @db.VarChar(128)
  slug                      String   @unique @db.VarChar(64)
  active                    Boolean  @default(true)
  settings                  Json
  // D05 amendment — per-tenant FCC 64.1200(d) internal-DNC retention,
  // default 5 years (FCC floor); operator may extend up to 99.
  internalDncRetentionYears Int      @default(5) @map("internal_dnc_retention_years") @db.SmallInt
  createdAt                 DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt                 DateTime @updatedAt @map("updated_at") @db.DateTime(6)

  users          User[]
  userGroups     UserGroup[]
  sipCredentials SipCredential[]
  campaigns      Campaign[]
  lists          List[]
  leads          Lead[]
  statuses       Status[]
  pauseCodes     PauseCode[]
  scripts        Script[]
  callTimes      CallTime[]
  dnc            Dnc[]
  callbacks      Callback[]
  hopperMirror   HopperMirror[]
  recordings     Recording[]
  dispositions   Disposition[]
  carriers       Carrier[]
  gateways       Gateway[]
  didNumbers     DidNumber[]
  ingroups       Ingroup[]
  ingroupAgents  IngroupAgent[]
  ivrTrees       IvrTree[]
  settingsRows   Setting[]

  @@map("tenants")
}

// =============================================================================
// 4.2  users   (A2 amendment: totp_required)
// =============================================================================

enum UserRole {
  agent
  supervisor
  admin
  superadmin
  integrator
}

model User {
  id            BigInt    @id @default(autoincrement())
  tenantId      BigInt    @default(1) @map("tenant_id")
  username      String    @db.VarChar(64)
  email         String?   @db.VarChar(128)
  // F02 ships VARCHAR(255) per amendment A6 — Argon2id encoded length;
  // F05 owns hashing and may persist its own width when it lands.
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  fullName      String?   @map("full_name") @db.VarChar(128)
  role          UserRole
  userGroupId   BigInt?   @map("user_group_id")
  active        Boolean   @default(true)
  hotkeysActive Boolean   @default(true) @map("hotkeys_active")
  totpRequired  Boolean   @default(false) @map("totp_required")
  lastLoginAt   DateTime? @map("last_login_at") @db.DateTime(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.DateTime(6)

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_users_tenant")
  userGroup      UserGroup?      @relation(fields: [userGroupId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_users_user_group")
  sipCredentials SipCredential[]
  callbacks      Callback[]      @relation("CallbacksOwner")
  callbacksMade  Callback[]      @relation("CallbacksCreatedBy")
  ingroupAgents  IngroupAgent[]
  ownedLeads     Lead[]
  dispositions   Disposition[]

  @@unique([tenantId, username], map: "uk_users_tenant_username")
  @@unique([tenantId, email], map: "uk_users_tenant_email")
  @@index([tenantId, userGroupId], map: "idx_users_t_group")
  @@index([tenantId, role, active], map: "idx_users_t_role_active")
  @@map("users")
}

// =============================================================================
// 4.3  user_groups
// =============================================================================

model UserGroup {
  id               BigInt   @id @default(autoincrement())
  tenantId         BigInt   @default(1) @map("tenant_id")
  name             String   @db.VarChar(64)
  allowedCampaigns Json     @map("allowed_campaigns")
  allowedIngroups  Json     @map("allowed_ingroups")
  createdAt        DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.DateTime(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_user_groups_tenant")
  users  User[]

  @@unique([tenantId, name], map: "uk_user_groups_tenant_name")
  @@map("user_groups")
}

// =============================================================================
// 4.4  sip_credentials  (envelope-encrypted)
// =============================================================================

model SipCredential {
  id            BigInt    @id @default(autoincrement())
  tenantId      BigInt    @default(1) @map("tenant_id")
  userId        BigInt    @map("user_id")
  sipUsername   String    @map("sip_username") @db.VarChar(64)
  sipPasswordCt Bytes     @map("sip_password_ct") @db.VarBinary(512)
  kekVersion    Int       @default(1) @map("kek_version") @db.SmallInt
  lastRotatedAt DateTime? @map("last_rotated_at") @db.DateTime(6)
  revokedAt     DateTime? @map("revoked_at") @db.DateTime(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.DateTime(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_sip_creds_tenant")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_sip_creds_user")

  @@unique([tenantId, sipUsername], map: "uk_sip_creds_tenant_user")
  @@index([tenantId, userId, kekVersion], map: "idx_sip_creds_t_user_kek")
  @@map("sip_credentials")
}

// =============================================================================
// 4.5  audit_log  (partitioned in 1_partition_log_tables migration)
//
// Composite PK (id, ts). Partitioned RANGE COLUMNS(ts).
// Prisma cannot emit PARTITION BY; Prisma's CREATE TABLE is dropped and
// re-issued in the partition migration. INSERT-only at the grant level.
// =============================================================================

enum AuditActorKind {
  user
  system
  worker
  external_api
}

model AuditLog {
  id          BigInt         @default(autoincrement())
  tenantId    BigInt         @default(1) @map("tenant_id")
  actorUserId BigInt?        @map("actor_user_id")
  actorKind   AuditActorKind @default(user) @map("actor_kind")
  action      String         @db.VarChar(64)
  entityType  String         @map("entity_type") @db.VarChar(32)
  entityId    String?        @map("entity_id") @db.VarChar(64)
  beforeJson  Json?          @map("before_json")
  afterJson   Json?          @map("after_json")
  requestId   String?        @map("request_id") @db.VarChar(64)
  ipAddress   String?        @map("ip_address") @db.VarChar(45)
  userAgent   String?        @map("user_agent") @db.VarChar(255)
  ts          DateTime       @db.DateTime(6)
  createdAt   DateTime       @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt   DateTime       @default(now()) @map("updated_at") @db.DateTime(6)

  @@id([id, ts])
  @@index([tenantId, actorUserId, ts], map: "idx_audit_t_actor_ts")
  @@index([tenantId, entityType, entityId, ts], map: "idx_audit_t_entity_ts")
  @@index([tenantId, action, ts], map: "idx_audit_t_action_ts")
  @@map("audit_log")
}

// =============================================================================
// 4.6  campaigns   (composite PK tenant_id, id)
// =============================================================================

enum DialMethod {
  MANUAL
  RATIO
  PROGRESSIVE
  ADAPT_HARD
  ADAPT_AVG
  ADAPT_TAPERED
}

enum NextAgentCall {
  longest_wait
  random
  fewest_calls
  rank
}

enum RecordingMode {
  NEVER
  ONDEMAND
  ALL
  ALLFORCE
}

enum AmdAction {
  drop
  vmdrop
  agent
}

enum PauseCodesRequired {
  OFF
  OPTIONAL
  FORCE
}

// C01 amendment — per-campaign policy when TZ resolution returns NONE.
enum UnknownTzPolicy {
  deny
  warn_pass
}

// E01 amendment — multi-list ordering / mixing strategy.
enum MultiListMix {
  EVEN
  MULTI
  NONE
}

model Campaign {
  tenantId               BigInt             @default(1) @map("tenant_id")
  id                     String             @db.VarChar(32)
  name                   String             @db.VarChar(128)
  active                 Boolean            @default(true)
  dialMethod             DialMethod         @default(MANUAL) @map("dial_method")
  autoDialLevel          Decimal            @default(0.00) @map("auto_dial_level") @db.Decimal(4, 2)
  adaptiveMaxLevel       Decimal            @default(3.00) @map("adaptive_max_level") @db.Decimal(4, 2)
  adaptiveDropPct        Decimal            @default(1.50) @map("adaptive_drop_pct") @db.Decimal(4, 2)
  dialTimeoutSec         Int                @default(22) @map("dial_timeout_sec") @db.SmallInt
  wrapupSeconds          Int                @default(10) @map("wrapup_seconds") @db.SmallInt
  nextAgentCall          NextAgentCall      @default(longest_wait) @map("next_agent_call")
  availableOnlyTally     Boolean            @default(false) @map("available_only_tally")
  hopperSizeTarget       Int                @default(0) @map("hopper_size_target")
  hopperMultiplier       Decimal            @default(2.0) @map("hopper_multiplier") @db.Decimal(3, 1)
  callerIdCarrierId      BigInt?            @map("caller_id_carrier_id")
  callerIdOverride       String?            @map("caller_id_override") @db.VarChar(16)
  recordingMode          RecordingMode      @default(ALL) @map("recording_mode")
  amdEnabled             Boolean            @default(false) @map("amd_enabled")
  amdAction              AmdAction          @default(drop) @map("amd_action")
  vmdropAudio            String?            @map("vmdrop_audio") @db.VarChar(255)
  safeHarborAudio        String?            @map("safe_harbor_audio") @db.VarChar(255)
  scriptId               BigInt?            @map("script_id")
  webformUrl             String?            @map("webform_url") @db.VarChar(512)
  dialStatusFilter       Json               @map("dial_status_filter")
  callTimeId             BigInt?            @map("call_time_id")
  useInternalDnc         Boolean            @default(true) @map("use_internal_dnc")
  useFederalDnc          Boolean            @default(true) @map("use_federal_dnc")
  useStateDnc            Boolean            @default(true) @map("use_state_dnc")
  pauseCodesRequired     PauseCodesRequired @default(OPTIONAL) @map("pause_codes_required")
  hotKeysActive          Boolean            @default(true) @map("hot_keys_active")
  closerIngroups         Json               @map("closer_ingroups")
  // C01 amendment §8.3 — per-campaign unknown-TZ policy (deny | warn_pass).
  unknownTzPolicy        UnknownTzPolicy    @default(deny) @map("unknown_tz_policy")
  // E01 amendment §10 — 16 hopper / pacing tunables (additive).
  dialLevel              Decimal            @default(1.50) @map("dial_level") @db.Decimal(4, 2)
  lockTtlSec             Int                @default(30) @map("lock_ttl_sec") @db.SmallInt
  minHopperLevel         Int                @default(50) @map("min_hopper_level")
  maxHopperLevel         Int                @default(5000) @map("max_hopper_level")
  hopperBufferMultiplier Decimal            @default(1.5) @map("hopper_buffer_multiplier") @db.Decimal(3, 1)
  recycleDelaySeconds    Int                @default(600) @map("recycle_delay_seconds")
  maxCallsPerLead        Int                @default(5) @map("max_calls_per_lead") @db.TinyInt
  dialStatuses           Json               @map("dial_statuses")
  lowWaterPct            Int                @default(25) @map("low_water_pct") @db.TinyInt
  highWaterPct           Int                @default(90) @map("high_water_pct") @db.TinyInt
  overFetchRatio         Decimal            @default(1.5) @map("over_fetch_ratio") @db.Decimal(3, 1)
  machineTerminal        Boolean            @default(true) @map("machine_terminal")
  leadFilterSql          String?            @map("lead_filter_sql") @db.Text
  multiListMix           MultiListMix       @default(EVEN) @map("multi_list_mix")
  createdAt              DateTime           @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt              DateTime           @updatedAt @map("updated_at") @db.DateTime(6)

  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_campaigns_tenant")
  callerIdCarrier Carrier?                 @relation("CampaignCallerCarrier", fields: [callerIdCarrierId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_campaigns_caller_carrier")
  script          Script?                  @relation(fields: [scriptId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_campaigns_script")
  callTime        CallTime?                @relation(fields: [callTimeId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_campaigns_calltime")
  campaignLists   CampaignList[]
  pauseCodes      PauseCode[]
  scripts         Script[]                 @relation("ScriptCampaign")
  callbacks       Callback[]
  hopperMirror    HopperMirror[]
  dispositions    Disposition[]
  statusOverrides CampaignStatusOverride[]

  @@id([tenantId, id])
  @@index([tenantId, active, dialMethod], map: "idx_campaigns_t_active_method")
  @@map("campaigns")
}

// =============================================================================
// E01 amendment §10/§12 — campaign_status_overrides
//
// Per-campaign override of `statuses.recycle_delay_seconds` (the column lives
// on D04's statuses table; this table allows the value to differ per campaign
// without touching the system-wide row).
// =============================================================================

model CampaignStatusOverride {
  tenantId            BigInt   @default(1) @map("tenant_id")
  campaignId          String   @map("campaign_id") @db.VarChar(32)
  statusCode          String   @map("status_code") @db.VarChar(8)
  recycleDelaySeconds Int?     @map("recycle_delay_seconds")
  maxCalls            Int?     @map("max_calls") @db.TinyInt
  notes               String?  @db.VarChar(255)
  createdAt           DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.DateTime(6)

  campaign Campaign @relation(fields: [tenantId, campaignId], references: [tenantId, id], onDelete: Cascade, onUpdate: NoAction, map: "fk_camp_status_ovr_campaign")

  @@id([tenantId, campaignId, statusCode])
  @@index([tenantId, statusCode], map: "idx_camp_status_ovr_t_status")
  @@map("campaign_status_overrides")
}

// =============================================================================
// 4.7  lists
// =============================================================================

model List {
  id               BigInt    @id @default(autoincrement())
  tenantId         BigInt    @default(1) @map("tenant_id")
  name             String    @db.VarChar(128)
  description      String?   @db.Text
  active           Boolean   @default(true)
  resetTime        DateTime? @map("reset_time") @db.Time(0)
  expiration       DateTime? @db.Date
  source           String?   @db.VarChar(64)
  // T04 amendment — per-list caller-ID waterfall tier 2 (overrides campaign).
  callerIdOverride String?   @map("caller_id_override") @db.VarChar(16)
  callerIdName     String?   @map("caller_id_name") @db.VarChar(32)
  createdAt        DateTime  @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.DateTime(6)

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_lists_tenant")
  campaignLists CampaignList[]
  leads         Lead[]

  @@unique([tenantId, name], map: "uk_lists_tenant_name")
  @@index([tenantId, active], map: "idx_lists_t_active")
  @@map("lists")
}

// =============================================================================
// 4.8  campaign_lists
// =============================================================================

model CampaignList {
  tenantId   BigInt   @default(1) @map("tenant_id")
  campaignId String   @map("campaign_id") @db.VarChar(32)
  listId     BigInt   @map("list_id")
  priority   Int      @default(0) @db.SmallInt
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime(6)

  campaign Campaign @relation(fields: [tenantId, campaignId], references: [tenantId, id], onDelete: Cascade, onUpdate: NoAction, map: "fk_camp_lists_campaign")
  list     List     @relation(fields: [listId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_camp_lists_list")

  @@id([tenantId, campaignId, listId])
  @@index([tenantId, listId], map: "idx_camp_lists_t_list")
  @@map("campaign_lists")
}

// =============================================================================
// 4.9  statuses (per-campaign or system default with __SYS__ sentinel)
// =============================================================================

model Status {
  tenantId      BigInt   @default(1) @map("tenant_id")
  campaignId    String   @map("campaign_id") @db.VarChar(32)
  status        String   @db.VarChar(8)
  description   String   @default("") @db.VarChar(128)
  selectable    Boolean  @default(true)
  humanAnswered Boolean  @default(false) @map("human_answered")
  sale          Boolean  @default(false)
  dnc           Boolean  @default(false)
  callback      Boolean  @default(false)
  notInterested Boolean  @default(false) @map("not_interested")
  hotkey        String?  @db.Char(1)
  createdAt     DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.DateTime(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_statuses_tenant")
  // Note: no DB-level FK to campaigns because the __SYS__ sentinel does not
  // exist in `campaigns`. App-layer enforces "real" campaign rows.

  @@id([tenantId, campaignId, status])
  @@map("statuses")
}

// =============================================================================
// 4.10  pause_codes
// =============================================================================

model PauseCode {
  id         BigInt   @id @default(autoincrement())
  tenantId   BigInt   @default(1) @map("tenant_id")
  campaignId String?  @map("campaign_id") @db.VarChar(32)
  code       String   @db.VarChar(16)
  name       String   @db.VarChar(64)
  billable   Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.DateTime(6)

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_pause_codes_tenant")
  campaign Campaign? @relation(fields: [tenantId, campaignId], references: [tenantId, id], onDelete: Cascade, onUpdate: NoAction, map: "fk_pause_codes_campaign")

  // Functional UNIQUE coalesced campaign_id added in extra-indexes migration:
  //   UNIQUE (tenant_id, IFNULL(campaign_id,'__SYS__'), code)
  @@index([tenantId, campaignId, code], map: "idx_pause_codes_t_camp_code")
  @@map("pause_codes")
}

// =============================================================================
// 4.11  scripts
// =============================================================================

model Script {
  id         BigInt   @id @default(autoincrement())
  tenantId   BigInt   @default(1) @map("tenant_id")
  name       String   @db.VarChar(64)
  body       String   @db.MediumText
  campaignId String?  @map("campaign_id") @db.VarChar(32)
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.DateTime(6)

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_scripts_tenant")
  campaign  Campaign?  @relation("ScriptCampaign", fields: [tenantId, campaignId], references: [tenantId, id], onDelete: NoAction, onUpdate: NoAction, map: "fk_scripts_campaign")
  campaigns Campaign[] // back-relation for campaigns.scriptId

  @@index([tenantId, campaignId], map: "idx_scripts_t_camp")
  @@map("scripts")
}

// =============================================================================
