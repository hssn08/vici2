// =============================================================================
// T04 amendment §7 — originate_audit
//
// Per-attempt outbound originate evidence (TCPA defense, 7y retention).
// Partitioned monthly RANGE COLUMNS(originated_at). INSERT + one-shot UPDATE
// (DAL guards UPDATE WHERE outcome='OTHER' AND outcome_at IS NULL).
// =============================================================================

enum OriginateMode {
  PROGRESSIVE
  PREDICTIVE
  MANUAL
  PREVIEW
}

enum OriginateDialTarget {
  CONFERENCE
  PARK
}

enum OriginateCidSource {
  per_call
  per_list
  local_presence
  campaign_default
}

enum OriginateTcpaDecision {
  ALLOW
  BLOCK
  SKIP
}

enum OriginateDncDecision {
  ALLOW
  BLOCK
}

enum OriginateConsentDecision {
  ALLOW
  PROMPT
  SKIP_RECORDING
  BLOCK
}

enum OriginateOutcome {
  SUCCESS
  TCPA_BLOCKED
  DNC_BLOCKED
  CONSENT_BLOCKED
  GATEWAY_LIMIT
  RATE_LIMITED
  GATEWAY_FAIL
  TIMEOUT
  JOB_ORPHANED
  OTHER
}

model OriginateAudit {
  id              BigInt                    @default(autoincrement())
  tenantId        BigInt                    @default(1) @map("tenant_id")
  attemptUuid     String                    @map("attempt_uuid") @db.VarChar(40)
  callUuid        String?                   @map("call_uuid") @db.VarChar(40)
  leadId          BigInt                    @map("lead_id")
  campaignId      String?                   @map("campaign_id") @db.VarChar(32)
  listId          BigInt?                   @map("list_id")
  agentId         BigInt?                   @map("agent_id")
  mode            OriginateMode
  dialTarget      OriginateDialTarget       @map("dial_target")
  carrierId       BigInt?                   @map("carrier_id")
  gatewayId       BigInt?                   @map("gateway_id")
  gatewayName     String?                   @map("gateway_name") @db.VarChar(64)
  callerIdNumber  String?                   @map("caller_id_number") @db.VarChar(16)
  callerIdSource  OriginateCidSource?       @map("caller_id_source")
  phoneE164       String                    @map("phone_e164") @db.VarChar(16)
  originatedAt    DateTime                  @map("originated_at") @db.DateTime(6)
  tcpaDecision    OriginateTcpaDecision?    @map("tcpa_decision")
  tcpaReason      String?                   @map("tcpa_reason") @db.VarChar(64)
  tcpaTzResolved  String?                   @map("tcpa_tz_resolved") @db.VarChar(64)
  dncDecision     OriginateDncDecision?     @map("dnc_decision")
  dncSources      Json?                     @map("dnc_sources")
  consentDecision OriginateConsentDecision? @map("consent_decision")
  consentState    String?                   @map("consent_state") @db.Char(2)
  bypassToken     String?                   @map("bypass_token") @db.VarChar(64)
  outcome         OriginateOutcome          @default(OTHER)
  outcomeAt       DateTime?                 @map("outcome_at") @db.DateTime(6)
  durationMs      Int?                      @map("duration_ms")
  errorMessage    String?                   @map("error_message") @db.Text
  fsHost          String?                   @map("fs_host") @db.VarChar(64)
  requestId       String?                   @map("request_id") @db.VarChar(64)
  ipAddress       String?                   @map("ip_address") @db.VarChar(45)
  createdAt       DateTime                  @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt       DateTime                  @default(now()) @map("updated_at") @db.DateTime(6)
  // C03 chain columns
  prevHash        String                    @default("") @map("prev_hash") @db.Char(64)
  rowHash         String                    @default("") @map("row_hash") @db.Char(64)
  hashAt          DateTime                  @default(now()) @map("hash_at") @db.DateTime(6)

  @@id([id, originatedAt])
  // Partition column must appear in every UNIQUE key (MySQL hard rule).
  // App-level idempotency: SELECT-then-INSERT inside a tx using attempt_uuid.
  @@unique([attemptUuid, originatedAt], map: "uq_originate_audit_attempt")
  @@index([tenantId, leadId, originatedAt], map: "idx_originate_audit_t_lead_ts")
  @@index([tenantId, campaignId, originatedAt], map: "idx_originate_audit_t_camp_ts")
  @@index([tenantId, outcome, originatedAt], map: "idx_originate_audit_t_outcome_ts")
  @@index([callUuid], map: "idx_originate_audit_call_uuid")
  @@index([tenantId, hashAt], map: "idx_originate_audit_t_hash_at")
  @@map("originate_audit")
}

// =============================================================================
// C02 + C03 amendments — Recording Consent State Matrix + chain columns
//
// C02 owns the state-matrix decision; C03 adds tamper-evident chain columns
// (prev_hash, row_hash, hash_at) populated by BEFORE INSERT trigger.
// INSERT-only, monthly partitioned. Column additions on tenants/campaigns/
// leads are inline above. vici2_app_rw gets INSERT + SELECT only.
// Retention: 7 years (C04 partition rotator).
// =============================================================================

// ConsentMode — the five recording-consent decision modes, low→high strictness.
// Mirrors Go's consent.Mode iota.
enum ConsentMode {
  ALLOW
  PROMPT_BEEP
  PROMPT_MESSAGE
  REQUIRE_ACTIVE
  SKIP
}

// RecordingPurpose — classifies why a call is recorded.
// PA §5704(15) B2B carve-out applies only to training / quality_control / monitoring.
enum RecordingPurpose {
  general
  training
  quality_control
  monitoring
}

// OptOutAction — what happens when a customer declines REQUIRE_ACTIVE consent.
enum OptOutAction {
  continue_no_record
  hangup
}

// ConsentLogStatus — the lifecycle status of a consent decision row.
// Two rows are written per call_uuid (INSERT-only — no UPDATE):
//   1. Decision-time row with status "pending".
//   2. Post-call status-time row with the final status from R01.
enum ConsentLogStatus {
  pending
  not_required
  prompted_accepted
  prompted_declined
  prompted_assumed
  beep_only
  skipped
}

// consent_log — INSERT-only per-call recording-consent audit trail.
//
// Partitioned monthly RANGE COLUMNS(recorded_at). No foreign keys (MySQL
// partitioned-table limitation). C03 adds prev_hash/row_hash/hash_at chain
// columns via BEFORE INSERT trigger; INSERT-only enforced via grants + triggers.
model ConsentLog {
  id            BigInt           @default(autoincrement())
  tenantId      BigInt           @default(1) @map("tenant_id")
  callUuid      String           @map("call_uuid") @db.VarChar(40)
  leadId        BigInt           @map("lead_id")
  campaignId    String           @map("campaign_id") @db.VarChar(32)
  userId        BigInt?          @map("user_id") // nil pre-bridge
  leadState     String?          @map("lead_state") @db.Char(2)
  callerState   String?          @map("caller_state") @db.Char(2)
  decision      ConsentMode
  mechanism     String           @db.VarChar(64)
  stateApplied  String?          @map("state_applied") @db.Char(2)
  consentStatus ConsentLogStatus @default(pending) @map("consent_status")
  reason        String           @db.VarChar(64)
  citation      String?          @db.VarChar(128)
  recordedAt    DateTime         @map("recorded_at") @db.DateTime(6)
  // C03 chain columns (populated by BEFORE INSERT trigger; clients do not write)
  prevHash      String           @default("") @map("prev_hash") @db.Char(64)
  rowHash       String           @default("") @map("row_hash") @db.Char(64)
  hashAt        DateTime         @default(now()) @map("hash_at") @db.DateTime(6)
  createdAt     DateTime         @default(now()) @map("created_at") @db.DateTime(6)

  @@id([id, recordedAt])
  @@index([tenantId, leadId, recordedAt], map: "idx_consent_log_t_lead_ts")
  @@index([tenantId, callUuid], map: "idx_consent_log_t_call")
  @@index([tenantId, stateApplied, recordedAt], map: "idx_consent_log_t_state_ts")
  @@index([tenantId, decision, recordedAt], map: "idx_consent_log_t_decision_ts")
  @@index([tenantId, hashAt], map: "idx_consent_log_t_hash_at")
  @@map("consent_log")
}

// =============================================================================
// C03 — audit_attestation
//
// One row per published S3 Merkle attestation (tenant × table × day).
// INSERT-only: audit_attestation_no_update / no_delete + hash_chain triggers.
// Partitioned by computed_at (monthly) — C04 owns rotation.
// =============================================================================

enum AuditAttestationTable {
  audit_log
  call_window_audit
  originate_audit
  consent_log
  dnc_sync_log
}

model AuditAttestation {
  id                   BigInt                 @default(autoincrement())
  tenantId             BigInt                 @default(1) @map("tenant_id")
  tableName            AuditAttestationTable  @map("table_name")
  windowDate           DateTime               @map("window_date") @db.Date
  rowCount             BigInt                 @default(0) @map("row_count")
  firstId              BigInt?                @map("first_id")
  lastId               BigInt?                @map("last_id")
  firstRowPrevHash     String                 @map("first_row_prev_hash") @db.Char(64)
  lastRowRowHash       String                 @map("last_row_row_hash") @db.Char(64)
  merkleRoot           String                 @map("merkle_root") @db.Char(64)
  keyId                String                 @map("key_id") @db.VarChar(64)
  signatureB64         String                 @map("signature_b64") @db.VarChar(96)
  s3Key                String                 @map("s3_key") @db.VarChar(255)
  s3Etag               String?                @map("s3_etag") @db.VarChar(64)
  s3UploadedAt         DateTime?              @map("s3_uploaded_at") @db.DateTime(6)
  // chain columns (chained per tenant_id + table_name)
  prevAttestationHash  String                 @default("") @map("prev_attestation_hash") @db.Char(64)
  attestationHash      String                 @default("") @map("attestation_hash") @db.Char(64)
  hashAt               DateTime               @default(now()) @map("hash_at") @db.DateTime(6)
  computedAt           DateTime               @map("computed_at") @db.DateTime(6)
  createdAt            DateTime               @default(now()) @map("created_at") @db.DateTime(6)

  @@id([id, computedAt])
  @@unique([tenantId, tableName, windowDate], map: "uk_t_table_date")
  @@index([tenantId, tableName, computedAt], map: "idx_t_table_computed")
  @@index([tenantId, hashAt], map: "idx_t_hash_at")
  @@map("audit_attestation")
}

// =============================================================================
// D02  imports  (D02 PLAN §4.1)
// =============================================================================

enum ImportStatus {
  queued
