  @@index([tenantId, campaignId, createdAt], map: "idx_cwa_t_campaign_ts")
  @@index([tenantId, stateCode, createdAt], map: "idx_cwa_t_state_ts")
  @@index([tenantId, callUuid], map: "idx_cwa_t_call_uuid")
  @@index([tenantId, hashAt], map: "idx_cwa_t_hash_at")
  @@map("call_window_audit")
}

