  channels  Json
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(6)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_notif_prefs_user")
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_notif_prefs_tenant")

  @@unique([tenantId, userId, category], map: "uk_notif_prefs_t_user_cat")
  @@map("notification_prefs")
