  createdAt DateTime      @default(now()) @map("created_at") @db.DateTime(6)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_notifications_user")
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_notifications_tenant")

  @@index([tenantId, userId, readAt, createdAt], map: "idx_notif_t_user_read")
  @@index([tenantId, userId, createdAt], map: "idx_notif_t_user_unread")
  @@map("notifications")
}

model NotificationPref {
  id        BigInt   @id @default(autoincrement())
