// I01.3 — queue_calls: inbound call audit (partitioned — no FK from Prisma)
// Partition management in SQL migration; Prisma manages schema only.
model QueueCall {
  id              BigInt    @default(autoincrement())
  tenantId        BigInt    @default(1) @map("tenant_id")
  callUuid        String    @map("call_uuid") @db.VarChar(40)
  ingroupId       String    @map("ingroup_id") @db.VarChar(32)
  didE164         String?   @map("did_e164") @db.VarChar(16)
  callerIdE164    String?   @map("caller_id_e164") @db.VarChar(16)
  leadId          BigInt?   @map("lead_id")
  enterAt         DateTime  @map("enter_at") @db.DateTime(6)
  baseScore       BigInt    @map("base_score")
  matchedSkills   Json?     @map("matched_skills")
  dispatchAt      DateTime? @map("dispatch_at") @db.DateTime(6)
  dispatchUserId  BigInt?   @map("dispatch_user_id")
  exitAt          DateTime? @map("exit_at") @db.DateTime(6)
  exitReason      QueueCallExitReason? @map("exit_reason")
  positionAtEntry Int?      @map("position_at_entry")
  waitSeconds     Int?      @map("wait_seconds")
  recordingUuid   String?   @map("recording_uuid") @db.VarChar(40)
  createdAt       DateTime  @default(now()) @map("created_at") @db.DateTime(6)

  @@id([id, enterAt])
  @@index([tenantId, ingroupId, enterAt], map: "idx_qc_t_ingroup_enter")
  @@index([tenantId, exitAt, exitReason], map: "idx_qc_t_exit")
  @@index([tenantId, leadId], map: "idx_qc_t_lead")
  @@index([tenantId, callUuid], map: "idx_qc_t_uuid")
  @@map("queue_calls")
}

enum QueueCallExitReason {
  answered
  caller_hangup
  timeout
  overflow
  callback
  full_at_entry
  agent_no_answer
}

// I01.4 — queue_log: per-event audit (partitioned)
model QueueLog {
  id           BigInt        @default(autoincrement())
  tenantId     BigInt        @default(1) @map("tenant_id")
  queueCallId  BigInt        @map("queue_call_id")
  eventAt      DateTime      @map("event_at") @db.DateTime(6)
  event        QueueLogEvent
  metadata     Json?

  @@id([id, eventAt])
  @@index([tenantId, queueCallId, eventAt], map: "idx_ql_t_qc")
  @@index([tenantId, event, eventAt], map: "idx_ql_t_event")
  @@map("queue_log")
}

enum QueueLogEvent {
  enter
  position_announce
  offer_callback
  accept_callback
  sticky_attempt
  dispatch
  agent_no_answer
  reroute
  overflow
  answer
  caller_hangup
  timeout
  full_block
}

// =============================================================================
// O03 — alert_receivers
