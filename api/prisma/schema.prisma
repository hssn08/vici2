// =============================================================================
// 4.24  call_log  (partitioned)
// =============================================================================

enum CallDirection {
  out
  in
}

enum AmdResult {
  none
  machine
  human
  unknown
}

model CallLog {
  id           BigInt        @default(autoincrement())
  tenantId     BigInt        @default(1) @map("tenant_id")
  uuid         String        @db.VarChar(40)
  parentUuid   String?       @map("parent_uuid") @db.VarChar(40)
  leadId       BigInt?       @map("lead_id")
  campaignId   String?       @map("campaign_id") @db.VarChar(32)
  listId       BigInt?       @map("list_id")
  userId       BigInt?       @map("user_id")
  direction    CallDirection
  phoneE164    String        @map("phone_e164") @db.VarChar(16)
  callerId     String?       @map("caller_id") @db.VarChar(16)
  carrierId    BigInt?       @map("carrier_id")
  gatewayId    BigInt?       @map("gateway_id")
  callStarted  DateTime      @map("call_started") @db.DateTime(6)
  callAnswered DateTime?     @map("call_answered") @db.DateTime(6)
  callEnded    DateTime?     @map("call_ended") @db.DateTime(6)
  ringSeconds  Int?          @map("ring_seconds")
  talkSeconds  Int?          @map("talk_seconds")
  holdSeconds  Int?          @map("hold_seconds")
  wrapSeconds  Int?          @map("wrap_seconds")
  status       String?       @db.VarChar(8)
  hangupCause  String?       @map("hangup_cause") @db.VarChar(32)
  amdResult    AmdResult     @default(none) @map("amd_result")
  isDrop       Boolean       @default(false) @map("is_drop")
  recordingId  BigInt?       @map("recording_id")
  createdAt    DateTime      @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt    DateTime      @default(now()) @map("updated_at") @db.DateTime(6)

  @@id([id, callStarted])
  @@unique([uuid, callStarted], map: "uk_call_log_uuid")
  @@index([tenantId, campaignId, callStarted], map: "idx_call_log_t_camp_started")
  @@index([tenantId, leadId, callStarted], map: "idx_call_log_t_lead_started")
  @@index([tenantId, userId, callStarted], map: "idx_call_log_t_user_started")
  @@index([tenantId, phoneE164, callStarted], map: "idx_call_log_t_phone_started")
  @@index([tenantId, status, callStarted], map: "idx_call_log_t_status_started")
  @@index([tenantId, carrierId, callStarted], map: "idx_call_log_t_carrier_started")
  @@map("call_log")
}

// =============================================================================
// 4.25  agent_log  (partitioned)
// =============================================================================

enum AgentEvent {
  login
  logout
  pause
  unpause
  ready
  call_start
  call_end
  dispo
  transfer
  hold
  retrieve
}

model AgentLog {
  id          BigInt     @default(autoincrement())
  tenantId    BigInt     @default(1) @map("tenant_id")
  userId      BigInt     @map("user_id")
  campaignId  String?    @map("campaign_id") @db.VarChar(32)
  callLogId   BigInt?    @map("call_log_id")
  eventAt     DateTime   @map("event_at") @db.DateTime(6)
  event       AgentEvent
  pauseCode   String?    @map("pause_code") @db.VarChar(16)
  durationSec Int?       @map("duration_sec")
  metadata    Json?
  createdAt   DateTime   @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt   DateTime   @default(now()) @map("updated_at") @db.DateTime(6)

  @@id([id, eventAt])
  @@index([tenantId, userId, eventAt], map: "idx_agent_log_t_user_event")
  @@index([tenantId, campaignId, eventAt], map: "idx_agent_log_t_camp_event")
  @@index([tenantId, callLogId], map: "idx_agent_log_t_call")
  @@map("agent_log")
}

// =============================================================================
// 4.26  recording_log  (partitioned)
// =============================================================================

enum ConsentStatus {
  not_required
  prompted_accepted
  prompted_declined
  assumed
}

model RecordingLog {
  id            BigInt        @default(autoincrement())
  tenantId      BigInt        @default(1) @map("tenant_id")
  uuid          String        @db.VarChar(40)
  callLogId     BigInt?       @map("call_log_id")
  leadId        BigInt?       @map("lead_id")
  campaignId    String?       @map("campaign_id") @db.VarChar(32)
  userId        BigInt?       @map("user_id")
  filename      String        @db.VarChar(255)
  storageUrl    String?       @map("storage_url") @db.VarChar(512)
  startTime     DateTime      @map("start_time") @db.DateTime(6)
  durationSec   Int?          @map("duration_sec")
  sizeBytes     BigInt?       @map("size_bytes")
  encodedAt     DateTime?     @map("encoded_at") @db.DateTime(6)
  consentStatus ConsentStatus @default(not_required) @map("consent_status")
  createdAt     DateTime      @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt     DateTime      @default(now()) @map("updated_at") @db.DateTime(6)

  @@id([id, startTime])
  @@unique([uuid, startTime], map: "uk_recording_log_uuid")
  @@index([tenantId, leadId, startTime], map: "idx_recording_log_t_lead_started")
  @@index([tenantId, campaignId, startTime], map: "idx_recording_log_t_camp_started")
  @@index([tenantId, callLogId], map: "idx_recording_log_t_call")
  @@index([tenantId, userId, startTime], map: "idx_recording_log_t_user_started")
  @@map("recording_log")
}

// =============================================================================
// 4.27  drop_log  (partitioned)
// =============================================================================

enum DropReason {
  no_agent
  timeout
  queue_full
}

model DropLog {
  id               BigInt     @default(autoincrement())
  tenantId         BigInt     @default(1) @map("tenant_id")
  callLogId        BigInt?    @map("call_log_id")
  campaignId       String     @map("campaign_id") @db.VarChar(32)
  phoneE164        String     @map("phone_e164") @db.VarChar(16)
  droppedAt        DateTime   @map("dropped_at") @db.DateTime(6)
  dropReason       DropReason @map("drop_reason")
  safeHarborPlayed Boolean    @default(false) @map("safe_harbor_played")
  createdAt        DateTime   @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt        DateTime   @default(now()) @map("updated_at") @db.DateTime(6)

  @@id([id, droppedAt])
  @@index([tenantId, campaignId, droppedAt], map: "idx_drop_log_t_camp_dropped")
  @@index([tenantId, callLogId], map: "idx_drop_log_t_call")
  @@map("drop_log")
}

// =============================================================================
// 4.28  settings (per-tenant key/value)
// =============================================================================

model Setting {
  tenantId  BigInt   @default(1) @map("tenant_id")
  k         String   @db.VarChar(64)
  v         Json
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_settings_tenant")

  @@id([tenantId, k])
  @@map("settings")
}

// =============================================================================
// A3  auth_config  (single-row F05 hook)
// =============================================================================

model AuthConfig {
  id                     Int @id @default(1)
  totpGracePeriodDays    Int @default(7) @map("totp_grace_period_days")
  passwordMinLength      Int @default(12) @map("password_min_length")
  refreshTokenTtlSeconds Int @default(2592000) @map("refresh_token_ttl_seconds")
  accessTokenTtlSeconds  Int @default(900) @map("access_token_ttl_seconds")
  lockoutAfterFailures   Int @default(5) @map("lockout_after_failures")
  lockoutWindowSeconds   Int @default(900) @map("lockout_window_seconds")

  @@map("auth_config")
}

// =============================================================================
// C01 amendment §8.1 — call_window_audit
//
// Per-decision TCPA audit log. Partitioned monthly RANGE COLUMNS(created_at).
// INSERT-only via grant + trigger pair (mirrors audit_log). C03 owns S3
// archival + retention rotation. NO foreign keys (partitioned-table rule).
// =============================================================================

enum CwaDecision {
  ALLOW
  ALLOW_WARN
  SKIP_UNTIL
  BLOCK_INVALID
}

enum CwaTzConfidence {
  KNOWN
  ZIP
  NXX
  NPA
  STATE_DEFAULT
  CAMPAIGN_DEFAULT
  NONE
}

enum CwaEnforcementPoint {
  hopper_filler
  originate_path
  pacing
  manual_dial
}

model CallWindowAudit {
  id                BigInt              @default(autoincrement())
  tenantId          BigInt              @default(1) @map("tenant_id")
  leadId            BigInt              @map("lead_id")
  phoneE164         String              @map("phone_e164") @db.VarChar(16)
  campaignId        String              @map("campaign_id") @db.VarChar(32)
  decision          CwaDecision
  reason            String              @db.VarChar(64)
  tzIana            String?             @map("tz_iana") @db.VarChar(40)
  tzConfidence      CwaTzConfidence?    @map("tz_confidence")
  stateCode         String?             @map("state_code") @db.Char(2)
  zip               String?             @db.VarChar(16)
  partyLocal        DateTime?           @map("party_local") @db.DateTime(6)
  partyDow          Int?                @map("party_dow") @db.TinyInt
  effectiveOpenMin  Int?                @map("effective_open_min") @db.SmallInt
  effectiveCloseMin Int?                @map("effective_close_min") @db.SmallInt
  ruleApplied       String?             @map("rule_applied") @db.VarChar(64)
  enforcementPoint  CwaEnforcementPoint @map("enforcement_point")
  nextOpenAt        DateTime?           @map("next_open_at") @db.DateTime(6)
  callUuid          String?             @map("call_uuid") @db.VarChar(64)
  createdAt         DateTime            @default(now()) @map("created_at") @db.DateTime(6)

  @@id([id, createdAt])
  @@index([tenantId, leadId, createdAt], map: "idx_cwa_t_lead_ts")
  @@index([tenantId, decision, createdAt], map: "idx_cwa_t_decision_ts")
  @@index([tenantId, campaignId, createdAt], map: "idx_cwa_t_campaign_ts")
  @@index([tenantId, stateCode, createdAt], map: "idx_cwa_t_state_ts")
  @@index([tenantId, callUuid], map: "idx_cwa_t_call_uuid")
  @@map("call_window_audit")
}

// =============================================================================
// C01 amendment §8.2 — state_holidays
//
// Admin-display lookup. Runtime gate uses an in-process HolidayCalendar
// (computed via Easter computus for LA Mardi Gras / Good Friday). NOT
// partitioned (small dataset; ~150 rows for 5y forward across all states).
// No tenant_id — global reference like phone_codes.
// =============================================================================

model StateHoliday {
  id          BigInt   @id @default(autoincrement())
  stateCode   String   @map("state_code") @db.Char(2)
  holidayDate DateTime @map("holiday_date") @db.Date
  name        String   @db.VarChar(64)
  citation    String?  @db.VarChar(128)
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.DateTime(6)

  @@unique([stateCode, holidayDate], map: "uk_state_holidays_state_date")
  @@index([holidayDate], map: "idx_state_holidays_date")
  @@map("state_holidays")
}

// =============================================================================
// D05 amendment §4.2 — dnc_sync_config
//
// Per-source (federal | state:XX | litigator) cron config + last-run state.
// Single row per source. Config secrets reference KEK-encrypted blobs in
// `config_json` (F05 helper).
// =============================================================================

enum DncSyncCadence {
  daily
  weekly
  monthly
  quarterly
}

model DncSyncConfig {
  source     String         @id @db.VarChar(32) // 'federal' | 'state:TX' | 'litigator'
  enabled    Boolean        @default(false)
  cadence    DncSyncCadence
  lastRunAt  DateTime?      @map("last_run_at") @db.DateTime(6)
  nextRunAt  DateTime?      @map("next_run_at") @db.DateTime(6)
  configJson Json?          @map("config_json")
  createdAt  DateTime       @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt  DateTime       @updatedAt @map("updated_at") @db.DateTime(6)

  @@index([enabled, nextRunAt], map: "idx_dnc_sync_config_enabled_next")
  @@map("dnc_sync_config")
}

// =============================================================================
// D05 amendment §4.x — dnc_sync_log
//
// One row per sync run (delta or full). INSERT-only via grant pattern.
// Partitioned monthly RANGE COLUMNS(started_at) to align with C04 rotator.
// =============================================================================

enum DncSyncKind {
  delta
  full
  bulk
}

enum DncSyncOutcome {
  success
  partial
  failed
}

model DncSyncLog {
  id          BigInt         @default(autoincrement())
  source      String         @db.VarChar(32)
  kind        DncSyncKind
  outcome     DncSyncOutcome @default(success)
  added       Int            @default(0)
  removed     Int            @default(0)
  errorCount  Int            @default(0) @map("error_count")
  fileHash    String?        @map("file_hash") @db.VarChar(128)
  startedAt   DateTime       @map("started_at") @db.DateTime(6)
  completedAt DateTime?      @map("completed_at") @db.DateTime(6)
  durationMs  Int?           @map("duration_ms")
  notes       String?        @db.Text
  createdAt   DateTime       @default(now()) @map("created_at") @db.DateTime(6)

  @@id([id, startedAt])
  @@index([source, startedAt], map: "idx_dnc_sync_log_source_started")
  @@index([outcome, startedAt], map: "idx_dnc_sync_log_outcome_started")
  @@map("dnc_sync_log")
}

// =============================================================================
// T04 amendment §7 — originate_audit
//
// Per-attempt outbound originate evidence (TCPA defense, 7y retention).
// Partitioned monthly RANGE COLUMNS(originated_at). INSERT + one-shot UPDATE
// (DAL guards UPDATE WHERE outcome='OTHER' AND outcome_at IS NULL).
// =============================================================================

enum OriginateMode {
  PROGRESSIVE
  PREDICTIVE
  MANUAL
  PREVIEW
}

enum OriginateDialTarget {
  CONFERENCE
  PARK
}

enum OriginateCidSource {
  per_call
  per_list
  local_presence
  campaign_default
}

enum OriginateTcpaDecision {
  ALLOW
  BLOCK
  SKIP
}

enum OriginateDncDecision {
  ALLOW
  BLOCK
}

enum OriginateConsentDecision {
  ALLOW
  PROMPT
  SKIP_RECORDING
  BLOCK
}

enum OriginateOutcome {
  SUCCESS
  TCPA_BLOCKED
  DNC_BLOCKED
  CONSENT_BLOCKED
  GATEWAY_LIMIT
  RATE_LIMITED
  GATEWAY_FAIL
  TIMEOUT
  JOB_ORPHANED
  OTHER
}

model OriginateAudit {
  id              BigInt                    @default(autoincrement())
  tenantId        BigInt                    @default(1) @map("tenant_id")
  attemptUuid     String                    @map("attempt_uuid") @db.VarChar(40)
  callUuid        String?                   @map("call_uuid") @db.VarChar(40)
  leadId          BigInt                    @map("lead_id")
  campaignId      String?                   @map("campaign_id") @db.VarChar(32)
  listId          BigInt?                   @map("list_id")
  agentId         BigInt?                   @map("agent_id")
  mode            OriginateMode
  dialTarget      OriginateDialTarget       @map("dial_target")
  carrierId       BigInt?                   @map("carrier_id")
  gatewayId       BigInt?                   @map("gateway_id")
  gatewayName     String?                   @map("gateway_name") @db.VarChar(64)
  callerIdNumber  String?                   @map("caller_id_number") @db.VarChar(16)
  callerIdSource  OriginateCidSource?       @map("caller_id_source")
  phoneE164       String                    @map("phone_e164") @db.VarChar(16)
  originatedAt    DateTime                  @map("originated_at") @db.DateTime(6)
  tcpaDecision    OriginateTcpaDecision?    @map("tcpa_decision")
  tcpaReason      String?                   @map("tcpa_reason") @db.VarChar(64)
  tcpaTzResolved  String?                   @map("tcpa_tz_resolved") @db.VarChar(64)
  dncDecision     OriginateDncDecision?     @map("dnc_decision")
  dncSources      Json?                     @map("dnc_sources")
  consentDecision OriginateConsentDecision? @map("consent_decision")
  consentState    String?                   @map("consent_state") @db.Char(2)
  bypassToken     String?                   @map("bypass_token") @db.VarChar(64)
  outcome         OriginateOutcome          @default(OTHER)
  outcomeAt       DateTime?                 @map("outcome_at") @db.DateTime(6)
  durationMs      Int?                      @map("duration_ms")
  errorMessage    String?                   @map("error_message") @db.Text
  fsHost          String?                   @map("fs_host") @db.VarChar(64)
  requestId       String?                   @map("request_id") @db.VarChar(64)
  ipAddress       String?                   @map("ip_address") @db.VarChar(45)
  createdAt       DateTime                  @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt       DateTime                  @default(now()) @map("updated_at") @db.DateTime(6)

  @@id([id, originatedAt])
  // Partition column must appear in every UNIQUE key (MySQL hard rule).
  // App-level idempotency: SELECT-then-INSERT inside a tx using attempt_uuid.
  @@unique([attemptUuid, originatedAt], map: "uq_originate_audit_attempt")
  @@index([tenantId, leadId, originatedAt], map: "idx_originate_audit_t_lead_ts")
  @@index([tenantId, campaignId, originatedAt], map: "idx_originate_audit_t_camp_ts")
  @@index([tenantId, outcome, originatedAt], map: "idx_originate_audit_t_outcome_ts")
  @@index([callUuid], map: "idx_originate_audit_call_uuid")
  @@map("originate_audit")
}
