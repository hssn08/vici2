// =============================================================================
// 4.26  recording_log  (partitioned)
// =============================================================================

enum ConsentStatus {
  not_required
  prompted_accepted
  prompted_declined
  assumed
}

// N07 amendment — transcript pipeline status state machine.
enum TranscriptStatus {
  pending          // recording uploaded; not yet enqueued
  queued           // BullMQ job created
  processing       // GPU worker has audio
  completed        // transcript.json uploaded; URI set
  failed           // terminal failure after retries
  skipped          // no transcription configured for this tenant
  consent_blocked  // consent_status blocks transcription
}

// R02 amendment §6.1 — recording upload lifecycle state machine.
enum RecordingLogLifecycle {
  recording_complete          // R01 wrote row; awaiting R02
  uploading                   // R02 picked up; upload in-flight
  uploaded                    // confirmed in S3; local file still present
  available                   // sweep complete; local file deleted; S3 is authoritative
  failed                      // R01 or R02 terminal failure
  corrupt                     // SHA-256 mismatch after 3 retries
  consent_declined_no_upload  // C02 prompted_declined or skipped → local file deleted without upload
  orphan                      // RECORD_STOP event fired but file not found on disk
  too_short                   // duration_sec < RECORD_MIN_SEC
}

model RecordingLog {
  id             BigInt                @default(autoincrement())
  tenantId       BigInt                @default(1) @map("tenant_id")
  uuid           String                @db.VarChar(40)
  callLogId      BigInt?               @map("call_log_id")
  leadId         BigInt?               @map("lead_id")
  campaignId     String?               @map("campaign_id") @db.VarChar(32)
  userId         BigInt?               @map("user_id")
  filename       String                @db.VarChar(255)
  storageUrl          String?               @map("storage_url") @db.VarChar(512)
  // N07 amendment — transcript pipeline columns
  transcriptUri       String?               @map("transcript_uri") @db.VarChar(512)
  transcriptStatus    TranscriptStatus      @default(pending) @map("transcript_status")
  transcriptLang      String?               @map("transcript_lang") @db.VarChar(16)
  transcriptWordCount Int?                  @map("transcript_word_count")
  // R02 amendment §6.1 — SHA-256 of WAV bytes (written post-upload)
  sha256         Bytes?                @map("sha256") @db.Binary(32)
  // R02 amendment §6.1 — upload pipeline lifecycle state
  lifecycleState RecordingLogLifecycle @default(recording_complete) @map("lifecycle_state")
  // R02 amendment §6.1 — terminal failure reason code (max 64 chars)
  failureReason  String?               @map("failure_reason") @db.VarChar(64)
  startTime      DateTime              @map("start_time") @db.DateTime(6)
  durationSec    Int?                  @map("duration_sec")
  sizeBytes      BigInt?               @map("size_bytes")
  encodedAt      DateTime?             @map("encoded_at") @db.DateTime(6)
  consentStatus  ConsentStatus         @default(not_required) @map("consent_status")
  createdAt      DateTime              @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt      DateTime              @default(now()) @map("updated_at") @db.DateTime(6)

  @@id([id, startTime])
  @@unique([uuid, startTime], map: "uk_recording_log_uuid")
  @@index([tenantId, leadId, startTime], map: "idx_recording_log_t_lead_started")
  @@index([tenantId, campaignId, startTime], map: "idx_recording_log_t_camp_started")
  @@index([tenantId, callLogId], map: "idx_recording_log_t_call")
  @@index([tenantId, userId, startTime], map: "idx_recording_log_t_user_started")
  @@index([tenantId, lifecycleState], map: "idx_recording_log_t_lifecycle")
  @@index([tenantId, transcriptStatus, startTime], map: "idx_recording_log_t_transcript")
  @@map("recording_log")
}

