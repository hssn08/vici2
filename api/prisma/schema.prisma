  @@id([areaCode, exchangeCode])
  @@index([state], map: "idx_phone_overrides_state")
  @@map("phone_codes_overrides")
}

// =============================================================================
// A4  zip_codes  (D03 ZIP → IANA cascade tier 2)
//                No tenant_id (global reference)
// =============================================================================

enum ZipConfidence {
  ZIP
}

model ZipCode {
  zip        String        @id @db.Char(5)
  tzIana     String        @map("tz_iana") @db.VarChar(40)
  state      String?       @db.Char(2)
  confidence ZipConfidence @default(ZIP)

  @@index([state], map: "idx_zip_codes_state")
  @@index([tzIana], map: "idx_zip_codes_tz")
  @@map("zip_codes")
}

// =============================================================================
// 4.16  callbacks
// =============================================================================

enum CallbackStatus {
  LIVE
  PENDING
  DONE
  DEAD
}

model Callback {
  id         BigInt         @id @default(autoincrement())
  tenantId   BigInt         @default(1) @map("tenant_id")
  leadId     BigInt         @map("lead_id")
  campaignId String         @map("campaign_id") @db.VarChar(32)
  userId     BigInt?        @map("user_id")
  callbackAt DateTime       @map("callback_at") @db.DateTime(6)
  comments   String?        @db.Text
  status     CallbackStatus @default(PENDING)
  createdBy  BigInt?        @map("created_by")
  createdAt  DateTime       @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt  DateTime       @updatedAt @map("updated_at") @db.DateTime(6)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_callbacks_tenant")
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_callbacks_lead")
  campaign Campaign @relation(fields: [tenantId, campaignId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction, map: "fk_callbacks_campaign")
  user     User?    @relation("CallbacksOwner", fields: [userId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_callbacks_user")
  creator  User?    @relation("CallbacksCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_callbacks_creator")

  @@index([tenantId, status, callbackAt], map: "idx_callbacks_t_status_due")
  @@index([tenantId, userId, callbackAt], map: "idx_callbacks_t_user_due")
  @@index([tenantId, leadId], map: "idx_callbacks_t_lead")
  @@map("callbacks")
}

// =============================================================================
