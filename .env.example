# =============================================================================
# vici2 — environment variables (committed example; copy to .env for local dev)
# =============================================================================
# Real .env is gitignored. Every var below MUST be present (or have a documented
# default) before any service can start. Secrets here are placeholders only.
# =============================================================================

# --- Database (MySQL 8) -------------------------------------------------------
VICI2_DB_HOST=mysql
VICI2_DB_PORT=3306
VICI2_DB_NAME=vici2
VICI2_DB_USER=vici2_app
VICI2_DB_PASSWORD=change-me-vici2-pw           # 16+ chars; never commit a real one
VICI2_DB_ROOT_PASSWORD=change-me-root-pw       # 16+ chars; never commit a real one
# DATABASE_URL drives Prisma; vici2_app is granted INSERT+SELECT only on
# audit_log and full DML elsewhere (see infra/mysql/init/01-databases.sql
# and api/prisma/migrations/20260506201700_audit_grants).
DATABASE_URL=mysql://vici2_app:change-me-vici2-pw@mysql:3306/vici2
# Go dialer DSN — same DB, go-sql-driver shape; loc=UTC matches my.cnf
# default_time_zone='+00:00' (F02 PLAN §10).
DATABASE_DSN=vici2_app:change-me-vici2-pw@tcp(mysql:3306)/vici2?parseTime=true&loc=UTC&charset=utf8mb4
# F05 bootstrap (super_admin user) — F02 amendment A6 renames from
# VICI2_BOOTSTRAP_ADMIN_PASSWORD. F02 does NOT seed this row; F05
# IMPLEMENT (`make db-bootstrap-superadmin`) consumes these.
BOOTSTRAP_SUPERADMIN_EMAIL=admin@example.com
BOOTSTRAP_SUPERADMIN_PASSWORD=change-me-bootstrap-pw   # 12+ chars
BOOTSTRAP_SUPERADMIN_TENANT_ID=1

# --- Redis 7 -----------------------------------------------------------------
VICI2_REDIS_URL=redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

# --- FreeSWITCH 1.10 ----------------------------------------------------------
SIGNALWIRE_TOKEN=                              # required to build FS image (signalwire/freeswitch)
FS_EVENT_SOCKET_PASSWORD=ClueCon               # change in any non-dev environment
FS_DEFAULT_SIP_PASSWORD=change-me-sip-pw       # default digest pwd for static directory entries (F05)
FS_XMLCURL_USER=fs                             # HTTP basic for future xml_curl bindings (F05/I01)
FS_XMLCURL_PASS=change-me-xmlcurl-pw
FS_HOST=localhost                              # what the browser hits for SIP.js
FS_WSS_PORT=7443
FS_ESL_HOST=host.docker.internal
FS_ESL_PORT=8021

# --- TURN (A02 + operator-deployed coturn share these) -----------------------
TURN_URL=                                      # e.g. turn:turn.example.com:3478
TURN_USERNAME=
TURN_PASSWORD=

# --- API service (Fastify, Node 20) ------------------------------------------
API_HTTP_PORT=3000
API_METRICS_PORT=9101

# === F05 Auth ================================================================
# Generate with: pnpm exec tsx api/src/scripts/gen-jwt-keys.ts
VICI2_JWT_ALG=EdDSA
VICI2_JWT_ISSUER=vici2-api
VICI2_JWT_PRIVATE_KEY_JWK=                     # base64(JSON JWK); REQUIRED for signing
VICI2_JWT_PUBLIC_KEYS_JWKS=                    # base64(JSON JWKS); REQUIRED for verifying
# KEK envelope encryption (AES-GCM-256). 32 random bytes, base64-encoded.
VICI2_KEK_V1=                                  # generate: openssl rand -base64 32
VICI2_KEK_CURRENT_VERSION=1
# HMAC pepper for Argon2id input. 32 random bytes, base64. Rotating forces
# re-hash-on-next-login for all users.
VICI2_PASSWORD_PEPPER=                         # generate: openssl rand -base64 32
# Set true for air-gapped installs (skips HIBP k-anonymity check).
HIBP_OFFLINE=false
# Token TTLs (seconds). Defaults: access 15min, refresh 30d agent / 7d admin.
VICI2_ACCESS_TTL_SEC=900
VICI2_REFRESH_TTL_AGENT_SEC=2592000
VICI2_REFRESH_TTL_ADMIN_SEC=604800
VICI2_REFRESH_TTL_INTEGRATOR_SEC=3600

# --- Dialer service (Go 1.22) -------------------------------------------------
DIALER_METRICS_PORT=9102
DIALER_GRPC_PORT=7000

# --- Workers service (Node 20) ------------------------------------------------
WORKERS_METRICS_PORT=9103

# --- Web (Next.js 14) ---------------------------------------------------------
WEB_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:3000

# --- Tenant (Phase 1 single-tenant; SPEC.md §4.5) ----------------------------
VICI2_DEFAULT_TENANT_ID=1

# --- Carriers (placeholders; T02 owns) ----------------------------------------
TWILIO_TERMINATION_USER=
TWILIO_TERMINATION_PASS=

# --- O01 Observability stack -------------------------------------------------
# Prometheus 3.x + Alertmanager 0.27+ + Grafana 11.x + exporters.
# See spec/modules/O01/PLAN.md and infra/observability/.
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3001                              # host-side; 3000 is taken by api
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin                   # change in any non-dev env
MYSQLD_EXPORTER_PORT=9105
VALKEY_EXPORTER_PORT=9106
NODE_EXPORTER_PORT=9107
# fs-exporter port (in-house freeswitch-exporter, not yet built)
FS_EXPORTER_PORT=9104

# --- O02 Backup + Restore -----------------------------------------------------
# S3 bucket for backups. Dev/CI may use LocalStack with --endpoint-url.
VICI2_BACKUP_BUCKET=vici2-backups-dev
# KMS alias for backup encryption. In dev/CI this can be any string (LocalStack ignores it).
VICI2_BACKUP_KEK_ALIAS=alias/vici2-backup-kek-dev
# AWS region for the backup bucket. Defaults to AWS_DEFAULT_REGION if unset.
VICI2_BACKUP_AWS_REGION=us-east-1
# Target environment for backup scripts (prod|staging|dev).
VICI2_ENV=dev
# Valkey data directory for bare-metal installs. Docker mode uses --docker-cp flag instead.
VICI2_VALKEY_DATA_DIR=/var/lib/docker/volumes/vici2_valkey_data/_data
# FreeSWITCH config directory.
VICI2_FS_CONFIG_DIR=/etc/freeswitch
# Prometheus node_exporter textfile collector directory.
# Backup scripts emit .prom files here for node_exporter to scrape.
VICI2_TEXTFILE_DIR=/var/lib/node_exporter/textfile_collector
# Staging MySQL host/port for restore-test (weekly automated restore verification).
VICI2_STAGING_DB_HOST=localhost
VICI2_STAGING_DB_PORT=3307

# --- Misc --------------------------------------------------------------------
NODE_ENV=development
GO_ENV=development
LOG_LEVEL=info
TZ=UTC
