# =============================================================================
# vici2 — environment variables (committed example; copy to .env for local dev)
# =============================================================================
# Real .env is gitignored. Every var below MUST be present (or have a documented
# default) before any service can start. Secrets here are placeholders only.
# =============================================================================

# --- Database (MySQL 8) -------------------------------------------------------
VICI2_DB_HOST=mysql
VICI2_DB_PORT=3306
VICI2_DB_NAME=vici2
VICI2_DB_USER=vici2_app
VICI2_DB_PASSWORD=change-me-vici2-pw           # 16+ chars; never commit a real one
VICI2_DB_ROOT_PASSWORD=change-me-root-pw       # 16+ chars; never commit a real one
# DATABASE_URL drives Prisma; vici2_app is granted INSERT+SELECT only on
# audit_log and full DML elsewhere (see infra/mysql/init/01-databases.sql
# and api/prisma/migrations/20260506201700_audit_grants).
DATABASE_URL=mysql://vici2_app:change-me-vici2-pw@mysql:3306/vici2
# Go dialer DSN — same DB, go-sql-driver shape; loc=UTC matches my.cnf
# default_time_zone='+00:00' (F02 PLAN §10).
DATABASE_DSN=vici2_app:change-me-vici2-pw@tcp(mysql:3306)/vici2?parseTime=true&loc=UTC&charset=utf8mb4
# F05 bootstrap (super_admin user) — F02 amendment A6 renames from
# VICI2_BOOTSTRAP_ADMIN_PASSWORD. F02 does NOT seed this row; F05
# IMPLEMENT (`make db-bootstrap-superadmin`) consumes these.
BOOTSTRAP_SUPERADMIN_EMAIL=admin@example.com
BOOTSTRAP_SUPERADMIN_PASSWORD=change-me-bootstrap-pw   # 12+ chars
BOOTSTRAP_SUPERADMIN_TENANT_ID=1

# --- Redis 7 -----------------------------------------------------------------
VICI2_REDIS_URL=redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

# --- FreeSWITCH 1.10 ----------------------------------------------------------
SIGNALWIRE_TOKEN=                              # required to build FS image (signalwire/freeswitch)
FS_EVENT_SOCKET_PASSWORD=ClueCon               # change in any non-dev environment
FS_HOST=localhost                              # what the browser hits for SIP.js
FS_WSS_PORT=7443
FS_ESL_HOST=host.docker.internal
FS_ESL_PORT=8021

# --- API service (Fastify, Node 20) ------------------------------------------
API_HTTP_PORT=3000
API_METRICS_PORT=9101
API_JWT_SECRET=change-me-jwt-secret            # 32+ random bytes base64
API_JWT_REFRESH_SECRET=change-me-refresh-secret

# --- Dialer service (Go 1.22) -------------------------------------------------
DIALER_METRICS_PORT=9102
DIALER_GRPC_PORT=7000

# --- Workers service (Node 20) ------------------------------------------------
WORKERS_METRICS_PORT=9103

# --- Web (Next.js 14) ---------------------------------------------------------
WEB_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:3000

# --- Tenant (Phase 1 single-tenant; SPEC.md §4.5) ----------------------------
VICI2_DEFAULT_TENANT_ID=1

# --- Carriers (placeholders; T02 owns) ----------------------------------------
TWILIO_TERMINATION_USER=
TWILIO_TERMINATION_PASS=

# --- O01 Observability stack -------------------------------------------------
# Prometheus 3.x + Alertmanager 0.27+ + Grafana 11.x + exporters.
# See spec/modules/O01/PLAN.md and infra/observability/.
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3001                              # host-side; 3000 is taken by api
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin                   # change in any non-dev env
MYSQLD_EXPORTER_PORT=9105
REDIS_EXPORTER_PORT=9106
NODE_EXPORTER_PORT=9107
# fs-exporter port (in-house freeswitch-exporter, not yet built)
FS_EXPORTER_PORT=9104

# --- Misc --------------------------------------------------------------------
NODE_ENV=development
GO_ENV=development
LOG_LEVEL=info
TZ=UTC
