<?xml version="1.0"?>
<!--
  vici2 FreeSWITCH global variables.
  F01 stub — F03 expands. Keep tenant-agnostic; carrier credentials are
  rendered separately under sip_profiles/external/.
-->
<include>

  <X-PRE-PROCESS cmd="set" data="default_password=$${env(FS_EVENT_SOCKET_PASSWORD)}"/>
  <X-PRE-PROCESS cmd="set" data="domain=$${local_ip_v4}"/>
  <X-PRE-PROCESS cmd="set" data="hold_music=local_stream://moh"/>

  <!-- SIP / RTP defaults -->
  <X-PRE-PROCESS cmd="set" data="external_rtp_ip=auto"/>
  <X-PRE-PROCESS cmd="set" data="external_sip_ip=auto"/>
  <X-PRE-PROCESS cmd="set" data="rtp_start_port=16384"/>
  <X-PRE-PROCESS cmd="set" data="rtp_end_port=32768"/>

  <!-- Codecs (G.711 only in MVP; F03/T02 may add Opus, G.722, G.729) -->
  <X-PRE-PROCESS cmd="set" data="global_codec_prefs=PCMU,PCMA"/>
  <X-PRE-PROCESS cmd="set" data="outbound_codec_prefs=PCMU,PCMA"/>

</include>
