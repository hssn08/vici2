<?xml version="1.0"?>
<!--
  Event Socket Library config.
  Binds to 0.0.0.0:8021 in dev so containers using `host.docker.internal` can
  connect. Password comes from $${default_password} which is fed by env var
  FS_EVENT_SOCKET_PASSWORD via vars.xml. F03 may tighten ACL.
-->
<configuration name="event_socket.conf" description="Socket Client">
  <settings>
    <param name="nat-map" value="false"/>
    <param name="listen-ip" value="0.0.0.0"/>
    <param name="listen-port" value="8021"/>
    <param name="password" value="$${default_password}"/>
    <param name="apply-inbound-acl" value="loopback.auto"/>
  </settings>
</configuration>
