<?xml version="1.0" encoding="UTF-8"?>
<!--
  Auto-generated by I03 VoicemailRenderer — DO NOT EDIT.
  Voicemail box: DEFAULT (id will be set after first DB seed) | Tenant: 1
  I03 PLAN §2.1: extension name = voicemail_{box_id}

  This is the seed/example extension for the DEFAULT in-group voicemail.
  IVR terminal_voicemail nodes and I01 overflow actions transfer here.
  VoicemailRenderer regenerates this file on admin saves.

  Wiring:
    - I02 IVR terminal_voicemail: transfer voicemail_1 XML default
    - I01 overflow closedAction=voicemail: transfer voicemail_1 XML default
-->
<include>
  <extension name="voicemail_1" continue="false">
    <condition field="destination_number" expression="^voicemail_1$">
      <!-- Tag call role and mailbox -->
      <action application="set" data="vici2_role=voicemail"/>
      <action application="set" data="vici2_vm_box_id=1"/>
      <action application="set" data="vici2_tenant_id=1"/>
      <!-- Answer the call -->
      <action application="answer"/>
      <!-- Play greeting (system default) -->
      <action application="playback" data="/var/lib/freeswitch/sounds/ivr/sys/sys_voicemail_default.wav"/>
      <!-- Beep tone: 500ms at 440 Hz -->
      <action application="playback" data="tone_stream://%(500,0,440)"/>
      <!-- Record caller's message (max 120 sec; silence threshold 200ms; 3 hits) -->
      <action application="record" data="/var/lib/freeswitch/recordings/${vici2_tenant_id}/voicemail/%Y/%m/%d/vm_1_${uuid}.wav 120 200 3"/>
      <!-- Notify API after recording -->
      <action application="set" data="vm_notify_url=http://api:3000/api/internal/voicemail/recorded"/>
      <action application="set" data="vm_post_body=box_id=1&amp;call_uuid=${uuid}&amp;tenant_id=1&amp;caller_number=${caller_id_number}&amp;duration_sec=${record_seconds}&amp;file_path=${record_name}"/>
      <action application="curl" data="${vm_notify_url} post ${vm_post_body}"/>
      <!-- Hang up gracefully -->
      <action application="hangup" data="NORMAL_CLEARING"/>
    </condition>
  </extension>
</include>
