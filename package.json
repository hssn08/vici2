{
  "name": "vici2",
  "private": true,
  "version": "0.0.0",
  "description": "Open-source Vicidial alternative on FreeSWITCH + MySQL + BYOC SIP",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.18.1 <21"
  },
  "scripts": {
    "prepare": "lefthook install || true",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "rbac:gen-golden": "api/node_modules/.bin/tsx scripts/rbac/gen-golden.ts",
    "rbac:check-coverage": "bash scripts/ci/check-rbac-coverage.sh"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.16.0",
    "@types/node": "^20.19.41",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.13.0",
    "lefthook": "^1.7.22",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.0"
  }
}
