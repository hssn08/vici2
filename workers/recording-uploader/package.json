{
  "name": "@vici2/recording-uploader",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "vici2 R02 — S3 recording upload worker (Redis Streams → BullMQ → S3)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx/esm 'src/**/*.test.ts' '__tests__/**/*.test.ts' || true",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/lib-storage": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@prisma/client": "^5.22.0",
    "@vici2/types": "workspace:*",
    "bullmq": "^5.76.10",
    "dotenv-flow": "^4.1.0",
    "ioredis": "^5.4.2",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "tsx": "^4.22.1",
    "typescript": "^5.6.3"
  }
}
