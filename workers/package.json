{
  "name": "@vici2/workers",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "vici2 workers — DNC sync, recording encode, transcribe",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx 'src/**/*.test.ts' || true",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@vici2/types": "workspace:*",
    "dotenv-flow": "^4.1.0",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
